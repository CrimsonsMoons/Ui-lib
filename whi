local FARM_SCAN_INTERVAL = 0.15
local FARM_LOCK_INTERVAL = 0.18
local FARM_HOVER_OFFSET = Vector3.new(0, 5.5, 0)
local FARM_NEAR_ISLAND_RANGE = 2200

local function refreshIslandFolders()
    islandsFolder = workspace:FindFirstChild("Islands")
    explorerFolder = workspace:FindFirstChild("Explorer")
end

local function isUUIDName(name)
    return typeof(name) == "string" and name:match("^%b{}$") ~= nil
end

local function getHRP()
    local character = player.Character or player.CharacterAdded:Wait()
    return character and character:FindFirstChild("HumanoidRootPart")
end

local function safeSetCFrame(hrp, cf)
    if not hrp or not hrp.Parent then return false end

    local character = hrp.Parent
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if humanoid then
        humanoid.Sit = false
        humanoid.PlatformStand = false
        humanoid:ChangeState(Enum.HumanoidStateType.Running)
    end

    hrp.AssemblyLinearVelocity = Vector3.zero
    hrp.AssemblyAngularVelocity = Vector3.zero
    hrp.CFrame = cf
    return true
end

local function isNearIslandPosition(pos, islandName)
    local anchors = positionsByIsland[islandName]
    if not anchors or #anchors == 0 then
        return true
    end

    for _, anchor in ipairs(anchors) do
        if (pos - anchor).Magnitude <= FARM_NEAR_ISLAND_RANGE then
            return true
        end
    end

    return false
end

local function addBodyIfValid(list, model, islandName, requireIslandRange)
    if not model or not model:IsA("Model") then return end
    if exclusions[model.Name] then return end

    -- Most wild horses/items use UUID model names. This skips pets, boats, and player mounts.
    if not isUUIDName(model.Name) then return end

    local body = model:FindFirstChild("Body")
    if not (body and body:IsA("BasePart") and body:IsDescendantOf(workspace)) then return end
    if requireIslandRange and not isNearIslandPosition(body.Position, islandName) then return end

    table.insert(list, body)
end

local function getAllBodies(islandName)
    refreshIslandFolders()

    local bodies = {}
    local scanned = {}

    local function scanContainer(container, requireIslandRange)
        if not container or scanned[container] then return end
        scanned[container] = true

        for _, model in ipairs(container:GetChildren()) do
            addBodyIfValid(bodies, model, islandName, requireIslandRange)
        end
    end

    -- Prefer the selected island folders first.
    if islandsFolder then
        scanContainer(islandsFolder:FindFirstChild(islandName), false)
    end

    if explorerFolder then
        scanContainer(explorerFolder:FindFirstChild(islandName), false)
    end

    -- Fallback: some horses can sit directly in Workspace. Only accept them if near the island anchors.
    scanContainer(workspace, true)

    return bodies
end

local function pickBestBody(islandName, hrp, previousBody)
    local bodies = getAllBodies(islandName)
    if #bodies == 0 then return nil end

    if previousBody and previousBody:IsDescendantOf(workspace) then
        for _, body in ipairs(bodies) do
            if body == previousBody then
                return previousBody
            end
        end
    end

    local origin = hrp and hrp.Position
    local bestBody, bestScore

    for _, body in ipairs(bodies) do
        if body and body.Parent then
            local score = origin and (body.Position - origin).Magnitude or 0
            if not bestScore or score < bestScore then
                bestScore = score
                bestBody = body
            end
        end
    end

    return bestBody
end

local function scanIslandPositionsUntilHorse(islandName)
    local hrp = getHRP()
    local positions = positionsByIsland[islandName] or {}
    if not hrp or #positions == 0 then
        task.wait(FARM_SCAN_INTERVAL)
        return nil
    end

    for _, pos in ipairs(positions) do
        if not farmSelectedIslandEnabled or selectedFarmIsland ~= islandName then
            return nil
        end

        safeSetCFrame(hrp, CFrame.new(pos + FARM_HOVER_OFFSET))

        -- Faster detection than the old 12-second blind wait.
        for _ = 1, 16 do
            if not farmSelectedIslandEnabled or selectedFarmIsland ~= islandName then
                return nil
            end

            local found = pickBestBody(islandName, hrp, currentFarmBody)
            if found then
                return found
            end

            task.wait(0.075)
        end
    end

    return nil
end

local function farmSelectedIslandLoop()
    while farmSelectedIslandEnabled do
        local islandName = selectedFarmIsland
        local hrp = getHRP()

        if not hrp then
            task.wait(0.25)
            continue
        end

        currentFarmBody = pickBestBody(islandName, hrp, currentFarmBody)

        if currentFarmBody and currentFarmBody:IsDescendantOf(workspace) then
            local bodyCF = currentFarmBody.CFrame
            local hoverCF = bodyCF + FARM_HOVER_OFFSET
            safeSetCFrame(hrp, hoverCF)
            task.wait(FARM_LOCK_INTERVAL)
        else
            currentFarmBody = scanIslandPositionsUntilHorse(islandName)
            task.wait(FARM_SCAN_INTERVAL)
        end
    end

    currentFarmBody = nil
end

