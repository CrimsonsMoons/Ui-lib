local function isSameColor3(a, b, tolerance)
    tolerance = tolerance or 2
    if typeof(a) ~= "Color3" or typeof(b) ~= "Color3" then
        return false
    end

    return math.abs((a.R * 255) - (b.R * 255)) <= tolerance
        and math.abs((a.G * 255) - (b.G * 255)) <= tolerance
        and math.abs((a.B * 255) - (b.B * 255)) <= tolerance
end

local function getProtectedColorName(color)
    for _, data in ipairs(PROTECTED_SPECIAL_COLORS) do
        if isSameColor3(color, data.color, 2) then
            return data.name
        end
    end

    return nil
end

local function getBackpackListRoot()
    local playerGui = player:FindFirstChildOfClass("PlayerGui")
    if not playerGui then
        return nil
    end

    local menus = playerGui:FindFirstChild("Menus")
    local backpack = menus and menus:FindFirstChild("Backpack")
    local main = backpack and backpack:FindFirstChild("Main")
    local inventory = main and main:FindFirstChild("Inventory")
    local content = inventory and inventory:FindFirstChild("Content")
    return content and content:FindFirstChild("List")
end

local function collectProtectedIndicatorItems()
    local protectedItems = {}
    local protectedIds = {}
    local listRoot = getBackpackListRoot()

    if not listRoot then
        return protectedItems, protectedIds, 0
    end

    for _, categoryFrame in ipairs(listRoot:GetChildren()) do
        local itemList = categoryFrame:FindFirstChild("List")
        if itemList then
            for _, itemFrame in ipairs(itemList:GetChildren()) do
                local indicator = itemFrame:FindFirstChild("SpecialIndicator")
                if indicator and indicator:IsA("GuiObject") then
                    local colorName = getProtectedColorName(indicator.BackgroundColor3)
                    if colorName then
                        local itemId = tostring(itemFrame.Name)
                        protectedIds[itemId] = true
                        table.insert(protectedItems, {
                            id = itemId,
                            color = colorName,
                        })
                    end
                end
            end
        end
    end

    return protectedItems, protectedIds, #protectedItems
end

local function refreshProtectedIndicatorCache(force)
    local now = os.clock()
    if not force and (now - protectedIndicatorState.updatedAt) < 0.25 then
        return protectedIndicatorState.items, protectedIndicatorState.ids, protectedIndicatorState.count
    end

    local items, ids, count = collectProtectedIndicatorItems()
    protectedIndicatorState.items = items
    protectedIndicatorState.ids = ids
    protectedIndicatorState.count = count
    protectedIndicatorState.updatedAt = now

    return items, ids, count
end

local function getFirstProtectedItemText()
    local items = protectedIndicatorState.items
    local first = items and items[1]
    if not first then
        return "unknown"
    end

    return ("%s [%s]"):format(tostring(first.id), tostring(first.color))
end

local function warnProtectedBlocked(actionName, itemId)
    local now = os.clock()
    if now < protectedSellWarnCooldown then
        return
    end

    protectedSellWarnCooldown = now + 3
    warn(("[CrimmyScriptz] Blocked %s to protect item %s. Protected SpecialIndicator colors are enabled."):format(
        tostring(actionName or "sell action"),
        tostring(itemId or getFirstProtectedItemText())
    ))
end

local function hasProtectedIndicatorItems()
    local _, _, count = refreshProtectedIndicatorCache(true)
    return count > 0, protectedIndicatorState.items, count
end

local function isProtectedItemId(value)
    if value == nil then
        return false
    end

    refreshProtectedIndicatorCache(false)
    return protectedIndicatorState.ids[tostring(value)] == true
end

local function scanValueForProtectedId(value, depth, seen)
    depth = depth or 0
    if depth > 8 then
        return false
    end

    local valueType = typeof(value)

    if valueType == "string" or valueType == "number" then
        if isProtectedItemId(value) then
            return true, tostring(value)
        end
        return false
    end

    if valueType == "Instance" then
        if isProtectedItemId(value.Name) then
            return true, tostring(value.Name)
        end
        return false
    end

    if type(value) == "table" then
        seen = seen or {}
        if seen[value] then
            return false
        end
        seen[value] = true

        local checked = 0
        for k, v in pairs(value) do
            checked += 1
            if checked > 300 then
                break
            end

            local keyHit, keyId = scanValueForProtectedId(k, depth + 1, seen)
            if keyHit then
                return true, keyId
            end

            local valueHit, valueId = scanValueForProtectedId(v, depth + 1, seen)
            if valueHit then
                return true, valueId
            end
        end
    end

    return false
end

local function scanArgsForProtectedId(...)
    for _, arg in ipairs({...}) do
        local found, itemId = scanValueForProtectedId(arg, 0, {})
        if found then
            return true, itemId
        end
    end

    return false
end

local function installProtectedSellRemoteGuard()
    if protectedIndicatorState.hookInstalled then
        return true
    end

    if protectedIndicatorState.hookAttempted then
        return false
    end

    protectedIndicatorState.hookAttempted = true

    if type(hookmetamethod) ~= "function" or type(getnamecallmethod) ~= "function" or type(newcclosure) ~= "function" then
        warn("[CrimmyScriptz] Protected item remote guard is not supported by this executor. Sell actions will hard-block when protected indicators are found.")
        return false
    end

    local ok, hookResult = pcall(function()
        originalProtectedNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
            local method = getnamecallmethod()

            if (method == "FireServer" or method == "InvokeServer") and typeof(self) == "Instance" then
                local className = self.ClassName
                if className == "RemoteEvent" or className == "RemoteFunction" then
                    local found, itemId = scanArgsForProtectedId(...)
                    if found then
                        warnProtectedBlocked(method, itemId)
                        return nil
                    end
                end
            end

            return originalProtectedNamecall(self, ...)
        end))
    end)

    protectedIndicatorState.hookInstalled = ok and originalProtectedNamecall ~= nil

    if not protectedIndicatorState.hookInstalled then
        warn("[CrimmyScriptz] Failed to install protected item remote guard: " .. tostring(hookResult))
    end

    return protectedIndicatorState.hookInstalled
end

local function prepareProtectedSellGuard(taskInfo)
    if not taskInfo or taskInfo.protectProtectedIndicators ~= true then
        return true
    end

    refreshProtectedIndicatorCache(true)

    if installProtectedSellRemoteGuard() then
        return true
    end

    local hasProtected, _, count = hasProtectedIndicatorItems()
    if hasProtected then
        warnProtectedBlocked(tostring(taskInfo.name) .. " fallback block", getFirstProtectedItemText())
        return false, ("blocked_%d_protected_indicator_items"):format(count)
    end

    return true
end

local function runRemoteLuaScript(taskInfo)
    local ready, reason = prepareProtectedSellGuard(taskInfo)
    if not ready then
        return false, reason
    end

    local ok, result = pcall(function()
        local source = game:HttpGet(taskInfo.url, true)
        local fn, compileErr = loadstring(source)
        if not fn then
            error(("Failed to load %s: %s"):format(taskInfo.name, tostring(compileErr)))
        end
        return fn()
    end)

    if not ok then
        warn(("[CrimmyScriptz] %s failed: %s"):format(taskInfo.name, tostring(result)))
    end

    return ok, result
end

local function startSellGroup(controller, taskList)
    if controller.thread then
        return
    end

    controller.thread = task.spawn(function()
        local lastRun = {}

        for _, taskInfo in ipairs(taskList) do
            lastRun[taskInfo.name] = 0
        end

        while controller.enabled do
            local now = os.clock()

            for _, taskInfo in ipairs(taskList) do
                if not controller.enabled then
                    break
                end

                if now - (lastRun[taskInfo.name] or 0) >= taskInfo.interval then
                    lastRun[taskInfo.name] = now
                    runRemoteLuaScript(taskInfo)
                    task.wait(0.05)
                end
            end

            task.wait(0.1)
        end

        controller.thread = nil
    end)
end

