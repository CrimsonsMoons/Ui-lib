--// Mercury-style compatibility adapter backed by NewGUI.
--// This lets all old functions transfer without rewriting every callback.
local GUI = {}
local TabAdapter = {}
TabAdapter.__index = TabAdapter

local function pick(tbl, ...)
    for _, key in ipairs({...}) do
        local value = tbl and tbl[key]
        if value ~= nil then
            return value
        end
    end
    return nil
end

local function toNewName(opts)
    return tostring(pick(opts, "Name", "name", "Title", "title") or "Unnamed")
end

local function toNewDescription(opts)
    return tostring(pick(opts, "Description", "description", "Tooltip", "tooltip") or "")
end

local function toNewIcon(opts)
    local icon = pick(opts, "Icon", "icon")
    if icon == nil or icon == "" then
        return Library.Icons and Library.Icons.dot or ""
    end
    return icon
end

function GUI:Tab(opts)
    opts = opts or {}
    local tab = Window:CreateTab({
        name = toNewName(opts),
        icon = toNewIcon(opts),
    })

    return setmetatable({
        _tab = tab,
        _name = toNewName(opts),
    }, TabAdapter)
end

function TabAdapter:Section(opts)
    opts = opts or {}
    self._tab:Section({
        name = toNewName(opts),
        subtitle = pick(opts, "Subtitle", "subtitle") or "",
        icon = toNewIcon(opts),
    })
    return self
end

function TabAdapter:Button(opts)
    opts = opts or {}
    return self._tab:Button({
        name = toNewName(opts),
        description = toNewDescription(opts),
        icon = toNewIcon(opts),
        callback = pick(opts, "Callback", "callback") or function() end,
    })
end

function TabAdapter:Toggle(opts)
    opts = opts or {}
    return self._tab:Toggle({
        name = toNewName(opts),
        description = toNewDescription(opts),
        icon = toNewIcon(opts),
        default = pick(opts, "StartingState", "startingState", "Default", "default") == true,
        flag = pick(opts, "Flag", "flag"),
        callback = pick(opts, "Callback", "callback") or function() end,
    })
end

function TabAdapter:Slider(opts)
    opts = opts or {}
    return self._tab:Slider({
        name = toNewName(opts),
        description = toNewDescription(opts),
        icon = toNewIcon(opts),
        min = pick(opts, "Min", "min") or 0,
        max = pick(opts, "Max", "max") or 100,
        default = pick(opts, "Default", "default", "StartingValue", "startingValue") or 0,
        suffix = pick(opts, "Suffix", "suffix") or "",
        callback = pick(opts, "Callback", "callback") or function() end,
    })
end

function TabAdapter:Dropdown(opts)
    opts = opts or {}
    return self._tab:Dropdown({
        name = toNewName(opts),
        description = toNewDescription(opts),
        icon = toNewIcon(opts),
        items = pick(opts, "Items", "items", "Options", "options") or {},
        options = pick(opts, "Items", "items", "Options", "options") or {},
        default = pick(opts, "Default", "default"),
        multi = pick(opts, "Multi", "multi", "Multiple", "multiple") == true,
        multiple = pick(opts, "Multi", "multi", "Multiple", "multiple") == true,
        callback = pick(opts, "Callback", "callback") or function() end,
    })
end

function TabAdapter:TextInput(opts)
    opts = opts or {}
    return self._tab:TextInput({
        name = toNewName(opts),
        description = toNewDescription(opts),
        icon = toNewIcon(opts),
        placeholder = pick(opts, "Placeholder", "placeholder") or "",
        default = pick(opts, "Default", "default") or "",
        callback = pick(opts, "Callback", "callback") or function() end,
    })
end

function TabAdapter:Label(opts)
    if type(opts) == "string" then
        return self._tab:Label({ text = opts })
    end
    opts = opts or {}
    return self._tab:Label({
        text = pick(opts, "Text", "text", "Name", "name") or "",
    })
end

function TabAdapter:Paragraph(opts)
    opts = opts or {}

    local title = pick(opts, "Title", "title", "Name", "name") or ""
    local text = pick(opts, "Text", "text", "Description", "description") or ""

    if self._tab.Paragraph then
        return self._tab:Paragraph({
            title = title,
            text = text,
        })
    elseif self._tab.Info then
        return self._tab:Info({
            text = title ~= "" and (title .. " - " .. text) or text,
        })
    elseif self._tab.Label then
        return self._tab:Label({
            text = title ~= "" and (title .. "\n" .. text) or text,
        })
    end
end

function TabAdapter:Info(opts)
    local text
    if type(opts) == "string" then
        text = opts
    else
        opts = opts or {}
        text = pick(opts, "Text", "text", "Description", "description") or ""
    end

    if self._tab.Info then
        return self._tab:Info({ text = text })
    elseif self._tab.Label then
        return self._tab:Label({ text = text })
    end
end

function TabAdapter:Divider()
    if self._tab.Divider then
        return self._tab:Divider()
    end
end

