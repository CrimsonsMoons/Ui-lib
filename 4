	local function getViewportLimit()
		local cam = workspace.CurrentCamera
		local size = cam and cam.ViewportSize or Vector2.new(1280, 720)
		return math.max(WIN_MIN_W, size.X - 24), math.max(WIN_MIN_H, size.Y - 24)
