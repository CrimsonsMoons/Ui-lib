		local navText=Instance.new("TextLabel",Tab._navBtn)
		navText.BackgroundTransparency=1; navText.BorderSizePixel=0
		navText.TextSize=14; navText.FontFace=Font.new("rbxasset://fonts/families/Ubuntu.json")
