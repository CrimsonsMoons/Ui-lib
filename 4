	-- Config save / load
	-- ══════════════════════════════════════════════════════════════════════
	local _cfgFolder = "VenturaUI"
	local _cfgFile   = _cfgFolder .. "/" .. options.name:gsub("[^%w%-%_]","_") .. ".json"

	local THEMES = Library.Themes

	local function _applyTheme(val)
		local t = THEMES[val]; if not t then return false end
		for k,v in pairs(t) do
			if k ~= "UserBox" and typeof(v) == "Color3" then Library.Theme[k] = v end
		end
		local surfaceNames = {Button=true, Toggle=true, Slider=true, Dropdown=true, Paragraph=true, ProgressBar=true, ColorPicker=true, Keybind=true, TextInput=true, Warning=false, Info=false, Success=false}
		local bgNames = {DDHeader=true, ResizeHandle=true, SliderValuePill=true, DropdownValue=true, DropdownList=true, SliderTrack=true}
		for _, obj in ipairs(SG:GetDescendants()) do
			pcall(function()
				if obj:IsA("UIStroke") then
					if obj.Parent and obj.Parent.Name ~= "AccentPreview" then obj.Color = Library.Theme.Border end
				elseif obj:IsA("TextLabel") or obj:IsA("TextBox") then
					if obj.TextColor3 == Color3.fromRGB(220,220,220) or obj.TextColor3 == Color3.fromRGB(230,230,238) then obj.TextColor3 = Library.Theme.TextPrimary end
				elseif obj:IsA("Frame") or obj:IsA("TextButton") then
					if surfaceNames[obj.Name] then obj.BackgroundColor3 = Library.Theme.Surface end
					if bgNames[obj.Name] then obj.BackgroundColor3 = Library.Theme.Background end
					if obj.Name == "TogglePill" and obj:GetAttribute("VenturaOn") ~= true then obj.BackgroundColor3 = Library.Theme.Background end
				end
			end)
		end
		tw(Main,    { BackgroundColor3 = Library.Theme.Background }, TI_SLOW)
		tw(Nav,     { BackgroundColor3 = Library.Theme.Nav }, TI_SLOW)
		tw(Topbar,  { BackgroundColor3 = Library.Theme.Topbar }, TI_SLOW)
		tw(UserBox, { BackgroundColor3 = t.UserBox or Library.Theme.Surface }, TI_SLOW)
		tw(userSep, { BackgroundColor3 = Library.Theme.Border }, TI_SLOW)
		tw(searchBar, { BackgroundColor3 = Library.Theme.Surface }, TI_SLOW)
		tw(_mainStroke, { Color = Library.Theme.Border }, TI_SLOW)
		for _, p in ipairs(navPatches) do tw(p, { BackgroundColor3 = Library.Theme.Nav }, TI_SLOW) end
		GUI._savedTheme = val
		return true
	end

	function GUI:SetTheme(name, silent)
		if _applyTheme(name) then
			if GUI._cfgSyncCallbacks and GUI._cfgSyncCallbacks.theme then pcall(GUI._cfgSyncCallbacks.theme, name) end
			if not silent then pcall(function() GUI:SaveConfig(true) end) end
			return true
		end
		return false
	end
	function GUI:GetTheme() return GUI._savedTheme or "Dark" end
	function GUI:GetThemes()
		local names = {}
		for name in pairs(THEMES) do table.insert(names, name) end
		table.sort(names)
		return names
	end
	function GUI:GetAccentPresets()
		local names = {}
		for name in pairs(Library.Accents) do table.insert(names, name) end
		table.sort(names)
		return names
	end
	function GUI:SetAccentPreset(name)
		local c = Library.Accents[name]
		if c then GUI:SetAccent(c); return true end
		return false
	end

	local function _c3ToHex(c)
		return string.format("%02X%02X%02X",
			math.floor(c.R*255+0.5), math.floor(c.G*255+0.5), math.floor(c.B*255+0.5))
	end
	local function _hexToC3(h)
		h = (h or ""):gsub("#","")
		if #h < 6 then return Library.Theme.Accent end
		return Color3.fromRGB(
			tonumber(h:sub(1,2),16) or 0,
			tonumber(h:sub(3,4),16) or 0,
			tonumber(h:sub(5,6),16) or 0)
	end
	local function _encodeConfig(t)
		local lines = {}
		for k,v in pairs(t) do
			if type(v) == "string" then
				table.insert(lines, k .. "=" .. v)
			else
				table.insert(lines, k .. "=" .. tostring(v))
			end
		end
		table.sort(lines)
		return table.concat(lines, "\n")
	end
	local function _decodeConfig(s)
		local t = {}
		for line in (s.."\n"):gmatch("([^\n]*)\n") do
			local k, v = line:match("^([^=]+)=(.*)$")
			if k and v then
				k = k:match("^%s*(.-)%s*$"); v = v:match("^%s*(.-)%s*$")
				if v == "true" then t[k] = true
				elseif v == "false" then t[k] = false
				elseif tonumber(v) then t[k] = tonumber(v)
				else t[k] = v end
			end
		end
		return t
	end

	local _saveQueued = false
	local function _configPayload()
		return _encodeConfig({
			accent    = _c3ToHex(Library.Theme.Accent),
			theme     = GUI._savedTheme or options.theme or "Dark",
			scale     = currentScale,
			winW      = math.floor(winW),
			winH      = math.floor(winH),
			renderW   = math.floor((MainWrap and MainWrap.AbsoluteSize.X > 0) and MainWrap.AbsoluteSize.X or select(1, getScaledWindowSize())),
			renderH   = math.floor((MainWrap and MainWrap.AbsoluteSize.Y > 0) and MainWrap.AbsoluteSize.Y or select(2, getScaledWindowSize())),
			toggleKey = keys.toggle.Name,
			minKey    = keys.minimize.Name,
		})
	end

	function GUI:SaveConfig(force)
		if not hasFileAPI() then
			warn("[VenturaUI] SaveConfig skipped: executor does not support writefile/readfile/isfile/isfolder/makefolder.")
			return false
		end
		if _saveQueued and not force then return true end
		_saveQueued = true
		local function writeNow()
			_saveQueued = false
			local ok, err = pcall(function()
				ensureFolder(_cfgFolder)
				writefile(_cfgFile, _configPayload())
			end)
			if not ok then warn("[VenturaUI] SaveConfig failed: " .. tostring(err)) end
			return ok
		end
		if force then return writeNow() end
		task.delay(0.15, writeNow)
		return true
	end

	function GUI:LoadConfig()
		if not hasFileAPI() then return nil end
		local okExists, exists = pcall(isfile, _cfgFile)
		if not okExists or not exists then return nil end
		local ok, raw = pcall(readfile, _cfgFile)
		if not ok or not raw or raw == "" then return nil end
		local ok2, data = pcall(_decodeConfig, raw)
		if not ok2 or not data or not next(data) then return nil end
		return data
	end

	GUI._cfgSyncCallbacks = {}

	function GUI:ApplyConfig(data)
		if not data then return end
		if data.theme and THEMES[data.theme] then
			_applyTheme(data.theme)
			if GUI._cfgSyncCallbacks.theme then pcall(GUI._cfgSyncCallbacks.theme, data.theme) end
		end
		if data.accent then
			local c = _hexToC3(data.accent)
			applyAccentToRegistered(c)
			if GUI._cfgSyncCallbacks.accent then pcall(GUI._cfgSyncCallbacks.accent, c) end
		end
		-- Load base window size AND scale, then apply the scaled size to the real UI immediately.
		-- Old behavior loaded winW/winH first and skipped applying scale whenever winW/winH existed.
		WIN_MAX_W, WIN_MAX_H = getViewportLimit()
		if data.winW then
			winW = math.clamp(tonumber(data.winW) or winW, WIN_MIN_W, WIN_MAX_W)
		end
		if data.winH then
			winH = math.clamp(tonumber(data.winH) or winH, WIN_MIN_H, WIN_MAX_H)
		end
		if data.scale then
			currentScale = math.clamp(tonumber(data.scale) or 100, 50, 200)
		end
		local sw, sh = applyWindowScale(false, minimized and 34 or nil)
		MainWrap.Size = UDim2.new(0, sw, 0, minimized and 34 or sh)
		task.defer(function() if not _destroyed then applyWindowScale(false, minimized and 34 or nil) end end)
		if GUI._cfgSyncCallbacks.scale then pcall(GUI._cfgSyncCallbacks.scale, currentScale) end
		if data.toggleKey then
			local ok, k = pcall(function() return Enum.KeyCode[data.toggleKey] end)
			if ok and k and k ~= Enum.KeyCode.Unknown then keys.toggle = k end
		end
		if data.minKey then
			local ok, k = pcall(function() return Enum.KeyCode[data.minKey] end)
			if ok and k and k ~= Enum.KeyCode.Unknown then keys.minimize = k end
		end
	end

	local _loadedConfig = GUI:LoadConfig()
	if _loadedConfig then
		GUI:ApplyConfig(_loadedConfig)
	elseif options.theme and THEMES[options.theme] then
		GUI:SetTheme(options.theme, true)
	end

