local function opt(t, lower, upper, default)
    if type(t) ~= "table" then return default end
    local value = t[lower]
    if value == nil and upper then value = t[upper] end
    if value == nil then value = default end
    return value
end

local function safeCall(fn, ...)
    if type(fn) ~= "function" then return nil end
    local ok, result = pcall(fn, ...)
    if not ok then warn("[NewMainUI] callback error: " .. tostring(result)) end
    return result
end

local function tween(object, goal, time)
    if not object then return nil end
    local ok, tw = pcall(function()
        return TweenService:Create(object, TweenInfo.new(time or 0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), goal)
    end)
    if ok and tw then tw:Play(); return tw end
    for k, v in pairs(goal) do pcall(function() object[k] = v end) end
    return nil
end

local function corner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 8)
    c.Parent = parent
    return c
end

local function stroke(parent, color, thickness)
    local s = Instance.new("UIStroke")
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Color = color or Color3.fromRGB(50,50,60)
    s.Thickness = thickness or 1
    s.Parent = parent
    return s
end

local function padding(parent, a, b, c, d)
    local p = Instance.new("UIPadding")
    p.PaddingTop = UDim.new(0, a or 0)
    p.PaddingRight = UDim.new(0, b or a or 0)
    p.PaddingBottom = UDim.new(0, c or a or 0)
    p.PaddingLeft = UDim.new(0, d or b or a or 0)
    p.Parent = parent
    return p
end

local function label(parent, text, size, color, bold)
    local l = Instance.new("TextLabel")
    l.BackgroundTransparency = 1
    l.BorderSizePixel = 0
    l.Text = tostring(text or "")
    l.TextColor3 = color or Library.Theme.TextPrimary
    l.TextSize = size or 13
    l.Font = bold and Enum.Font.GothamBold or Enum.Font.Gotham
    l.TextXAlignment = Enum.TextXAlignment.Left
    l.TextYAlignment = Enum.TextYAlignment.Center
    l.TextTruncate = Enum.TextTruncate.AtEnd
    l.Parent = parent
    return l
end

local function buttonBase(parent)
    local b = Instance.new("TextButton")
    b.AutoButtonColor = false
    b.Text = ""
    b.BorderSizePixel = 0
    b.Parent = parent
    return b
end

local function getRootGui()
    local root
    pcall(function()
        if type(gethui) == "function" then root = gethui() end
    end)
    if root then return root end
    pcall(function() root = CoreGui end)
    if root then return root end
    if LocalPlayer then
        local pg = LocalPlayer:FindFirstChildOfClass("PlayerGui") or LocalPlayer:WaitForChild("PlayerGui", 5)
        if pg then return pg end
    end
    return game:GetService("StarterGui")
end

local function protectGui(gui)
    pcall(function()
        if syn and type(syn.protect_gui) == "function" then syn.protect_gui(gui) end
    end)
end

local function destroyOld(name)
    local roots = {}
    local r = getRootGui()
    if r then table.insert(roots, r) end
    if LocalPlayer then
        local pg = LocalPlayer:FindFirstChildOfClass("PlayerGui")
        if pg then table.insert(roots, pg) end
    end
    for _, root in ipairs(roots) do
        for _, child in ipairs(root:GetChildren()) do
            if child:IsA("ScreenGui") and (child.Name == name or child.Name == "VenturaUI") then
                pcall(function() child:Destroy() end)
            end
        end
    end
end

local function hasFileApi()
    return type(writefile) == "function" and type(readfile) == "function" and type(isfile) == "function" and type(isfolder) == "function" and type(makefolder) == "function"
end

local function sanitizeFileName(s)
    return tostring(s or "Default"):gsub("[^%w_%-]", "_")
end

local function colorToHex(c)
    return string.format("%02X%02X%02X", math.floor(c.R * 255 + 0.5), math.floor(c.G * 255 + 0.5), math.floor(c.B * 255 + 0.5))
end

local function hexToColor(hex, fallback)
    hex = tostring(hex or ""):gsub("#", "")
    if #hex ~= 6 or not hex:match("^[%da-fA-F]+$") then return fallback end
    return Color3.fromRGB(tonumber(hex:sub(1,2),16) or 0, tonumber(hex:sub(3,4),16) or 0, tonumber(hex:sub(5,6),16) or 0)
end

local function textSize(text, size, font)
    local ok, bounds = pcall(function()
        return TextService:GetTextSize(tostring(text or ""), size or 12, font or Enum.Font.Gotham, Vector2.new(10000, 1000))
    end)
    if ok then return bounds end
    return Vector2.new(#tostring(text or "") * 7, 18)
end

local function makeDraggable(frame, dragHandle, onFinished)
    local dragging = false
    local dragStart
    local startPos

    dragHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if not dragging then return end
        if input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch then return end
        local delta = input.Position - dragStart
        frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            if dragging and onFinished then safeCall(onFinished) end
            dragging = false
        end
    end)
end

local function newThemeState(themeName, accent)
    local theme = nil
    if type(themeName) == "table" then
        theme = themeName
    else
        theme = Library.Themes[tostring(themeName or "Dark")] or Library.Themes.Dark
    end
    local state = {}
    for k, v in pairs(theme) do state[k] = v end
    if accent then state.Accent = accent end
    return state
end

local function applyThemeTable(target, theme)
    for k, v in pairs(theme) do
        Library.Theme[k] = v
    end
    if target and target._themeObjects then
        for i = #target._themeObjects, 1, -1 do
            local item = target._themeObjects[i]
            local obj = item.obj
            if obj and obj.Parent then
                pcall(function() obj[item.prop] = Library.Theme[item.key] or item.fallback end)
            else
                table.remove(target._themeObjects, i)
            end
        end
    end
    if target and target._accentObjects then
        for i = #target._accentObjects, 1, -1 do
            local item = target._accentObjects[i]
            local obj = item.obj
            if obj and obj.Parent then
                pcall(function() obj[item.prop] = Library.Theme.Accent end)
            else
                table.remove(target._accentObjects, i)
            end
        end
    end
end

local function registerTheme(window, obj, prop, key, fallback)
    table.insert(window._themeObjects, {obj=obj, prop=prop, key=key, fallback=fallback})
    pcall(function() obj[prop] = Library.Theme[key] or fallback end)
    return obj
end

local function registerAccent(window, obj, prop)
    table.insert(window._accentObjects, {obj=obj, prop=prop or "BackgroundColor3"})
    pcall(function() obj[prop or "BackgroundColor3"] = Library.Theme.Accent end)
    return obj
end

local function createControlFrame(window, parent, height)
    local frame = Instance.new("Frame")
    frame.Name = "Control"
    frame.BackgroundColor3 = Library.Theme.Surface
    frame.BorderSizePixel = 0
    frame.Size = UDim2.new(1, 0, 0, height or 44)
    frame.Parent = parent
    corner(frame, 8)
    local st = stroke(frame, Library.Theme.Border, 1)
    registerTheme(window, frame, "BackgroundColor3", "Surface", Library.Theme.Surface)
    registerTheme(window, st, "Color", "Border", Library.Theme.Border)
    return frame
end

local function resolveParent(host)
    if host._content then return host._content end
    if host._parentTab and host._sectionContent then return host._sectionContent end
    return host.Content or host.Container or host
end

local ControlMixin = {}

function ControlMixin:Button(options)
    options = options or {}
    local window = self._window
    local parent = resolveParent(self)
    local frame = createControlFrame(window, parent, 42)
    local icon = opt(options, "icon", "Icon", nil)
    local name = opt(options, "name", "Name", "Button")
    local desc = opt(options, "description", "Description", nil)
    local title = label(frame, (icon and tostring(icon) .. "  " or "") .. tostring(name), 13, Library.Theme.TextPrimary, true)
    title.Position = UDim2.new(0, 12, 0, desc and 4 or 0)
    title.Size = UDim2.new(1, -24, desc and 0.52 or 1, 0)
    registerTheme(window, title, "TextColor3", "TextPrimary", Library.Theme.TextPrimary)
    if desc then
        local d = label(frame, desc, 11, Library.Theme.TextSecondary, false)
        d.Position = UDim2.new(0, 12, 0.48, 0)
        d.Size = UDim2.new(1, -24, 0.44, 0)
        registerTheme(window, d, "TextColor3", "TextSecondary", Library.Theme.TextSecondary)
    end
    local hit = buttonBase(frame)
    hit.BackgroundTransparency = 1
    hit.Size = UDim2.new(1, 0, 1, 0)
    hit.MouseEnter:Connect(function() tween(frame, {BackgroundColor3 = Library.Theme.SurfaceHover}, 0.12) end)
    hit.MouseLeave:Connect(function() tween(frame, {BackgroundColor3 = Library.Theme.Surface}, 0.12) end)
    hit.MouseButton1Click:Connect(function() safeCall(opt(options, "callback", "Callback", nil)) end)
    return {frame=frame, Fire=function() safeCall(opt(options, "callback", "Callback", nil)) end}
end

function ControlMixin:Toggle(options)
    options = options or {}
    local window = self._window
    local parent = resolveParent(self)
    local frame = createControlFrame(window, parent, 48)
    local icon = opt(options, "icon", "Icon", nil)
    local name = opt(options, "name", "Name", "Toggle")
    local desc = opt(options, "description", "Description", nil)
    local title = label(frame, (icon and tostring(icon) .. "  " or "") .. tostring(name), 13, Library.Theme.TextPrimary, true)
    title.Position = UDim2.new(0, 12, 0, desc and 5 or 0)
    title.Size = UDim2.new(1, -78, desc and 0.5 or 1, 0)
    registerTheme(window, title, "TextColor3", "TextPrimary", Library.Theme.TextPrimary)
    if desc then
        local d = label(frame, desc, 11, Library.Theme.TextSecondary, false)
        d.Position = UDim2.new(0, 12, 0.5, 0)
        d.Size = UDim2.new(1, -78, 0.42, 0)
        registerTheme(window, d, "TextColor3", "TextSecondary", Library.Theme.TextSecondary)
    end
    local pill = Instance.new("Frame")
    pill.Name = "TogglePill"
    pill.Size = UDim2.new(0, 44, 0, 22)
    pill.Position = UDim2.new(1, -58, 0.5, -11)
    pill.BorderSizePixel = 0
    pill.Parent = frame
    corner(pill, 99)
    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 18, 0, 18)
    knob.Position = UDim2.new(0, 2, 0.5, -9)
    knob.BackgroundColor3 = Color3.fromRGB(245,245,245)
    knob.BorderSizePixel = 0
    knob.Parent = pill
    corner(knob, 99)

    local value = opt(options, "default", "StartingState", false) == true
    local callback = opt(options, "callback", "Callback", nil)
    local control = {frame=frame, Value=value}
    local function render()
        if value then
            pill.BackgroundColor3 = Library.Theme.Accent
            knob.Position = UDim2.new(1, -20, 0.5, -9)
        else
            pill.BackgroundColor3 = Library.Theme.BorderHover
            knob.Position = UDim2.new(0, 2, 0.5, -9)
        end
    end
    function control:Set(v, silent)
        value = v == true
        control.Value = value
        render()
        if not silent then safeCall(callback, value) end
    end
    function control:Get() return value end
    local hit = buttonBase(frame)
    hit.BackgroundTransparency = 1
    hit.Size = UDim2.new(1, 0, 1, 0)
    hit.MouseButton1Click:Connect(function() control:Set(not value) end)
    render()
    return control
end

