        local tabButton = buttonBase(nav)
        tabButton.Name = "Tab_" .. tostring(tabName)
        tabButton.Size = UDim2.new(1, 0, 0, 36)
        tabButton.BackgroundColor3 = Library.Theme.Surface
        tabButton.TextColor3 = Library.Theme.TextSecondary
        tabButton.TextSize = 12
        tabButton.Font = Enum.Font.GothamBold
        tabButton.TextXAlignment = Enum.TextXAlignment.Left
        tabButton.Text = "   " .. (tabIcon ~= "" and tostring(tabIcon) .. "  " or "") .. tostring(tabName)
        corner(tabButton, 8)
        registerTheme(window, tabButton, "BackgroundColor3", "Surface", Library.Theme.Surface)
        registerTheme(window, tabButton, "TextColor3", "TextSecondary", Library.Theme.TextSecondary)

        local page = Instance.new("ScrollingFrame")
        page.Name = "Page_" .. tostring(tabName)
        page.BackgroundTransparency = 1
        page.BorderSizePixel = 0
        page.ScrollBarThickness = 4
        page.ScrollBarImageColor3 = Library.Theme.Accent
        page.CanvasSize = UDim2.new(0, 0, 0, 0)
        page.AutomaticCanvasSize = Enum.AutomaticSize.Y
        page.Size = UDim2.new(1, 0, 1, 0)
        page.Visible = false
        page.Parent = pageHolder
        registerAccent(window, page, "ScrollBarImageColor3")
        local content = Instance.new("Frame")
        content.Name = "Content"
        content.BackgroundTransparency = 1
        content.BorderSizePixel = 0
        content.Size = UDim2.new(1, -6, 0, 0)
        content.AutomaticSize = Enum.AutomaticSize.Y
        content.Parent = page
        local layout = Instance.new("UIListLayout")
        layout.SortOrder = Enum.SortOrder.LayoutOrder
        layout.Padding = UDim.new(0, 8)
        layout.Parent = content

        local tab = {_window=window, _content=content, Button=tabButton, Page=page, Name=tabName}
        for k, v in pairs(ControlMixin) do tab[k] = v end
        function tab:Activate()
            if window._activeTab then
                window._activeTab.Page.Visible = false
                window._activeTab.Button.BackgroundColor3 = Library.Theme.Surface
                window._activeTab.Button.TextColor3 = Library.Theme.TextSecondary
            end
            page.Visible = true
            tabButton.BackgroundColor3 = Library.Theme.Accent
            tabButton.TextColor3 = Color3.fromRGB(255,255,255)
            window._activeTab = tab
        end
        tabButton.MouseButton1Click:Connect(function() tab:Activate() end)
        table.insert(window.Tabs, tab)
        if not window._activeTab then tab:Activate() end
        return tab
    end

    function window:Tab(tabOptions) return self:CreateTab(tabOptions) end

    function window:SetTheme(newTheme)
        if type(newTheme) == "table" then
            applyThemeTable(self, newTheme)
            self._themeName = "Custom"
        else
            self._themeName = tostring(newTheme or "Dark")
            local nextTheme = newThemeState(self._themeName, self._accent)
            applyThemeTable(self, nextTheme)
        end
        if self._activeTab then self._activeTab:Activate() end
        self:MarkConfigDirty()
        return true
    end

    function window:SetAccent(color)
        if typeof(color) ~= "Color3" then return false end
        self._accent = color
        Library.Theme.Accent = color
        applyThemeTable(self, Library.Theme)
        if self._activeTab then self._activeTab:Activate() end
        self:MarkConfigDirty()
        return true
    end

    function window:SetAccentPreset(preset)
        local color = Library.Accents[tostring(preset or "")]
        if not color then return false end
        return self:SetAccent(color)
    end

    function window:GetThemes()
        local out = {}
        for k in pairs(Library.Themes) do table.insert(out, k) end
        table.sort(out)
        return out
    end

    function window:GetAccentPresets()
        local out = {}
        for k in pairs(Library.Accents) do table.insert(out, k) end
        table.sort(out)
        return out
    end

    function window:SetSubtitle(text) sub.Text = tostring(text or "") end
    function window:SetMinimized(state) setMinimized(state) end
    function window:IsMinimized() return self._minimized end
    function window:Toggle() setMinimized(not self._minimized) end
    function window:GetVersion() return Library.Version end

    window.notify = function(titleText, bodyText, duration)
        return window:Notify(titleText, bodyText, duration)
    end

    function window:NavSection() return true end

    function window:Notify(titleText, bodyText, duration)
        duration = tonumber(duration) or 3
        local card = Instance.new("Frame")
        card.Name = "Notification"
        card.AnchorPoint = Vector2.new(1, 1)
        card.Position = UDim2.new(1, 340, 1, -18)
        card.Size = UDim2.new(0, 310, 0, 74)
        card.BackgroundColor3 = Library.Theme.Surface
        card.BorderSizePixel = 0
        card.Parent = sg
        corner(card, 10)
        local cs = stroke(card, Library.Theme.BorderHover, 1)
        registerTheme(window, card, "BackgroundColor3", "Surface", Library.Theme.Surface)
        registerTheme(window, cs, "Color", "BorderHover", Library.Theme.BorderHover)
        local bar = Instance.new("Frame")
        bar.BackgroundColor3 = Library.Theme.Accent
        bar.BorderSizePixel = 0
        bar.Position = UDim2.new(0, 8, 0, 10)
        bar.Size = UDim2.new(0, 3, 1, -20)
        bar.Parent = card
        corner(bar, 99)
        registerAccent(window, bar, "BackgroundColor3")
        local t = label(card, tostring(titleText or name), 14, Library.Theme.TextPrimary, true)
        t.Position = UDim2.new(0, 20, 0, 9)
        t.Size = UDim2.new(1, -30, 0, 24)
        registerTheme(window, t, "TextColor3", "TextPrimary", Library.Theme.TextPrimary)
        local b = label(card, tostring(bodyText or ""), 12, Library.Theme.TextSecondary, false)
        b.Position = UDim2.new(0, 20, 0, 35)
        b.Size = UDim2.new(1, -30, 0, 28)
        b.TextWrapped = true
        registerTheme(window, b, "TextColor3", "TextSecondary", Library.Theme.TextSecondary)
        tween(card, {Position=UDim2.new(1, -18, 1, -18)}, 0.25)
        task.delay(duration, function()
            if card and card.Parent then
                local tw = tween(card, {Position=UDim2.new(1, 340, 1, -18)}, 0.22)
                task.delay(0.25, function() if card then card:Destroy() end end)
            end
        end)
        return card
    end

    function window:MarkConfigDirty()
        if self._configQueued then return end
        self._configQueued = true
        task.delay(0.45, function()
            if self._destroyed then return end
            self._configQueued = false
            self:SaveConfig(true)
        end)
    end

    function window:_configPayload()
        local payload = {
            theme=self._themeName or "Dark",
            accent=colorToHex(self._accent or Library.Theme.Accent),
            x=main.Position.X.Offset,
            y=main.Position.Y.Offset,
            bx=bubble.Position.X.Offset,
            by=bubble.Position.Y.Offset,
            minimized=self._minimized == true
        }
        if watermarkFrame then
            payload.wx = watermarkFrame.Position.X.Offset
            payload.wy = watermarkFrame.Position.Y.Offset
        end
        return payload
    end

    function window:SaveConfig(silent)
        if not hasFileApi() then return false end
        pcall(function() if not isfolder("VenturaUI") then makefolder("VenturaUI") end end)
        local ok, encoded = pcall(function() return HttpService:JSONEncode(self:_configPayload()) end)
        if ok and encoded then
            pcall(function() writefile(self._configPath, encoded) end)
            return true
        end
        if not silent then warn("[NewMainUI] Could not encode config") end
        return false
    end

    function window:LoadConfig()
        if not hasFileApi() or not isfile(self._configPath) then return false end
        local ok, raw = pcall(function() return readfile(self._configPath) end)
        if not ok then return false end
        local ok2, data = pcall(function() return HttpService:JSONDecode(raw) end)
        if not ok2 or type(data) ~= "table" then return false end
        if data.theme then self:SetTheme(data.theme) end
        if data.accent then self:SetAccent(hexToColor(data.accent, self._accent or Library.Theme.Accent)) end
        if data.x and data.y then main.Position = UDim2.new(0, tonumber(data.x) or 0, 0, tonumber(data.y) or 0) end
        if data.bx and data.by then bubble.Position = UDim2.new(0, tonumber(data.bx) or 18, 0, tonumber(data.by) or 180) end
        if watermarkFrame and data.wx and data.wy then watermarkFrame.Position = UDim2.new(1, tonumber(data.wx) or -14, 0, tonumber(data.wy) or 14) end
        if data.minimized ~= nil then setMinimized(data.minimized == true) end
        return true
    end

    function window:ResetConfig()
        if hasFileApi() and isfile(self._configPath) then pcall(function() delfile(self._configPath) end) end
        return true
    end

    function window:ExportConfig(copy)
        local ok, encoded = pcall(function() return HttpService:JSONEncode(self:_configPayload()) end)
        encoded = ok and encoded or "{}"
        if copy and type(setclipboard) == "function" then pcall(function() setclipboard(encoded) end) end
        return encoded
    end

    function window:ImportConfig(raw, saveAfter)
        local ok, data = pcall(function() return HttpService:JSONDecode(tostring(raw or "")) end)
        if not ok or type(data) ~= "table" then return false end
        if data.theme then self:SetTheme(data.theme) end
        if data.accent then self:SetAccent(hexToColor(data.accent, Library.Theme.Accent)) end
        if saveAfter then self:SaveConfig(true) end
        return true
    end

    function window:Destroy()
        self._destroyed = true
        if opt(options, "onClose", "OnClose", nil) then safeCall(opt(options, "onClose", "OnClose", nil)) end
        pcall(function() sg:Destroy() end)
    end

    function window:Close() self:Destroy() end

    mini.MouseButton1Click:Connect(function() setMinimized(true) end)
    bubble.MouseButton1Click:Connect(function() setMinimized(false) end)
    close.MouseButton1Click:Connect(function() window:Destroy() end)
    UserInputService.InputBegan:Connect(function(input, gpe)
        if gpe or window._destroyed then return end
        if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == toggleKey then
            window:Toggle()
        end
    end)

    if autoLoad then pcall(function() window:LoadConfig() end) end

    if opt(options, "settingsTab", "SettingsTab", true) ~= false then
        local settings = window:CreateTab({name="Settings", icon=Library.Icons.settings})
        settings:Section({name="UI Settings", icon=Library.Icons.palette})
        settings:Dropdown({name="Theme", items=window:GetThemes(), default=window._themeName or "Dark", callback=function(v) window:SetTheme(v) end})
        settings:Dropdown({name="Accent", items=window:GetAccentPresets(), default="Blue", callback=function(v) window:SetAccentPreset(v) end})
        settings:Button({name="Save UI Preferences", icon=Library.Icons.save, callback=function() window:SaveConfig(); window:Notify("Config", "UI preferences saved.", 2) end})
        settings:Button({name="Reset UI Preferences", icon=Library.Icons.trash, callback=function() window:ResetConfig(); window:Notify("Config", "Saved UI preferences reset.", 2) end})
        if #window.Tabs > 1 then window.Tabs[1]:Activate() end
    end

    Library.__lastWindow = window
    return window
end

function Library:Create(options)
    return self:new(options)
end

function Library:Notify(title, text, duration)
    local temp = self.__lastWindow
    if temp and type(temp.Notify) == "function" then return temp:Notify(title, text, duration) end
end

return Library
