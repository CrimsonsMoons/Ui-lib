				task.wait(0.08)
				tw(MainWrap, {Size=UDim2.new(0,sw,0,0)}, TI_FAST, function()
					pcall(function() SG:Destroy() end)
				end)
			end)
		else
			tw(MainWrap, {Size=UDim2.new(0,sw,0,0)}, TI_FAST, function()
				pcall(function() SG:Destroy() end)
			end)
		end
	end

