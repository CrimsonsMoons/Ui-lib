	local _resizeSnapEnabled = options.resizeSnap ~= false
	local _resizeSnapMode = tostring(options.resizeSnapMode or "center"):lower()
	local _lastViewportSize = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or Vector2.new(1280, 720)

	local function _snapMainToViewport(sw, sh)
		local cam = workspace.CurrentCamera
		local vps = cam and cam.ViewportSize or Vector2.new(1280, 720)
		if _resizeSnapMode == "corner" or _resizeSnapMode == "top-left" or _resizeSnapMode == "topleft" then
			MainWrap.Position = UDim2.new(0, math.floor(sw / 2 + 14), 0, math.floor(sh / 2 + 14))
		else
			MainWrap.Position = UDim2.new(0, math.floor(vps.X / 2), 0, math.floor(vps.Y / 2))
		end
	end

	local function _snapSmallUIsToViewport()
		-- Window resize recovery: no drag borders during normal use, but resize keeps UI visible.
		if wmFrame and wmFrame.Parent then
			wmFrame.AnchorPoint = Vector2.new(1, 0)
			wmFrame.Position = UDim2.new(1, WM_DEFAULT_X, 0, WM_DEFAULT_Y)
