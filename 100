local function textHeight(text, width, size, fontEnum)
	local ok, bounds = pcall(function()
		return TextService:GetTextSize(tostring(text or ""), tonumber(size) or 12, fontEnum or Enum.Font.SourceSans, Vector2.new(math.max(width, 24), 10000))
	end)
	return ok and bounds.Y or math.max(16, math.ceil(#tostring(text or "") / 42) * 16)
end

local function clampTextWidth(text, size, minW, maxW)
	return math.clamp(math.floor(textWidth(text, size or 12, Enum.Font.SourceSans) + 0.5), minW or 44, maxW or 140)
end

local function safeTween(obj, goal, ti, cb)
	if not obj then return nil end
	return tw(obj, goal, ti, cb)
end

local function hasFileAPI()
	return type(writefile) == "function"
		and type(readfile) == "function"
		and type(isfile) == "function"
		and type(isfolder) == "function"
		and type(makefolder) == "function"
end

local function ensureFolder(path)
	if not hasFileAPI() then return false end
	local ok = pcall(function()
		if not isfolder(path) then makefolder(path) end
	end)
	return ok
end

local _ttFrame, _ttLabel, _ttConn
local function setupTooltip(sg)
	-- Ventura 5.1 tooltip fix:
	-- The old tooltip was always 24px tall, so wrapped/long text could hang outside
	-- the dark background. This version measures + wraps text, then sizes the
	-- background card to fully cover the description.
	_ttFrame = Instance.new("Frame", sg)
	_ttFrame.Name = "_Tooltip"
	_ttFrame.BackgroundColor3 = Color3.fromRGB(12, 12, 12)
	_ttFrame.BorderSizePixel = 0
	_ttFrame.Size = UDim2.new(0, 160, 0, 28)
	_ttFrame.Visible = false
	_ttFrame.ZIndex = 9999
	_ttFrame.ClipsDescendants = false
	corner(_ttFrame, 6)
	stroke(_ttFrame, Color3.fromRGB(70, 70, 70), 1)

	local tipPad = Instance.new("UIPadding", _ttFrame)
	tipPad.PaddingTop = UDim.new(0, 7)
	tipPad.PaddingBottom = UDim.new(0, 7)
	tipPad.PaddingLeft = UDim.new(0, 9)
	tipPad.PaddingRight = UDim.new(0, 9)

	_ttLabel = Instance.new("TextLabel", _ttFrame)
	_ttLabel.Name = "TooltipText"
	_ttLabel.BackgroundTransparency = 1
	_ttLabel.BorderSizePixel = 0
	_ttLabel.TextSize = 11
	_ttLabel.FontFace = Font.new("rbxasset://fonts/families/Ubuntu.json")
	_ttLabel.TextColor3 = Color3.fromRGB(210, 210, 210)
	_ttLabel.TextXAlignment = Enum.TextXAlignment.Left
	_ttLabel.TextYAlignment = Enum.TextYAlignment.Top
	_ttLabel.TextWrapped = true
	_ttLabel.TextTruncate = Enum.TextTruncate.None
	_ttLabel.Size = UDim2.new(1, 0, 1, 0)
	_ttLabel.ZIndex = 10000

	if _ttConn then pcall(function() _ttConn:Disconnect() end) end
	_ttConn = RunService.RenderStepped:Connect(function()
		if _ttFrame and _ttFrame.Visible then
			if UIS:GetFocusedTextBox() then _ttFrame.Visible = false; return end
			local mp = UIS:GetMouseLocation()
			local vp = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or Vector2.new(1280, 720)
			local w, h = _ttFrame.AbsoluteSize.X, _ttFrame.AbsoluteSize.Y
			local x = mp.X + 16
			local y = mp.Y + 18
			if x + w + 8 > vp.X then x = mp.X - w - 16 end
			if y + h + 8 > vp.Y then y = mp.Y - h - 16 end
			x = math.clamp(x, 6, math.max(6, vp.X - w - 6))
			y = math.clamp(y, 6, math.max(6, vp.Y - h - 6))
			_ttFrame.Position = UDim2.new(0, x, 0, y)
		end
	end)
end

local function _tooltipSizeFor(text)
	text = tostring(text or "")
	local rawW = textWidth(text, 11, Enum.Font.SourceSans)
	local w = math.clamp(math.floor(rawW + 26), 110, 340)
	local innerW = math.max(40, w - 18)
	local h = math.clamp(math.floor(textHeight(text, innerW, 11, Enum.Font.SourceSans) + 17), 28, 190)
	return w, h
end

local function addTooltip(frame, text)
	text = tostring(text or "")
	if not frame or text == "" or MOBILE then return end
	local showing = false
	local alive = true

	local function show()
		if not alive or not _ttLabel or not _ttFrame or UIS:GetFocusedTextBox() then return end
		showing = true
		_ttLabel.Text = text
		local w, h = _tooltipSizeFor(text)
		_ttFrame.Size = UDim2.new(0, w, 0, h)
		_ttFrame.Visible = true
		_ttFrame.BackgroundTransparency = 0
	end

	local function hide()
		showing = false
		if _ttFrame then _ttFrame.Visible = false end
	end

	pcall(function() frame.MouseEnter:Connect(show) end)
	pcall(function() frame.MouseLeave:Connect(hide) end)
	frame.InputBegan:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseMovement then show() end
	end)
	frame.InputEnded:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseMovement and showing then hide() end
	end)
	frame.AncestryChanged:Connect(function(_, parent)
		if parent == nil then alive = false; if showing then hide() end end
	end)
end

