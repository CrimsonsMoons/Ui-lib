	function GUI:RegisterTheme(name, themeData, applyNow)
		name = tostring(name or ""):match("^%s*(.-)%s*$")
		if name == "" or type(themeData) ~= "table" then return false end
		local newTheme = {}
		for k, v in pairs(themeData) do newTheme[k] = v end
		Library.Themes[name] = newTheme
		if GUI._themeDropdown and type(GUI._themeDropdown.SetItems) == "function" then
