	function GUI:SaveConfig(force, profileName)
		if GUI._configApplying then return true end
		if not hasFileAPI() then
			warn("[VenturaUI] UI auto-save skipped: executor does not support writefile/readfile/isfile/isfolder/makefolder.")
			return false
		end
		if GUI._saveQueued and not force then return true end
		GUI._saveQueued = true
		local function writeNow()
			GUI._saveQueued = false
			if _destroyed then return false end
			local ok, err = pcall(function()
				_ensureConfigFolders()
				writefile(_cfgFile, GUI:_configPayload())
			end)
			if not ok then warn("[VenturaUI] UI auto-save failed: " .. tostring(err)) else GUI._configDirty = false end
			return ok
		end
		if force then return writeNow() end
		task.delay(0.2, writeNow)
		return true
	end

	function GUI:LoadConfig(profileName)
		if not hasFileAPI() then return nil end
		local targetFile = _cfgFile
		local okExists, exists = pcall(isfile, targetFile)
		if not okExists or not exists then
			-- Backwards compatibility: older Ventura builds used VenturaUI/<WindowName>.json.
			local legacyFile = _cfgFolder .. "/" .. _cfgBaseName .. ".json"
			local okLegacy, legacyExists = pcall(isfile, legacyFile)
			if okLegacy and legacyExists then targetFile = legacyFile; exists = true; okExists = true end
		end
		if not okExists or not exists then return nil end
		local ok, raw = pcall(readfile, targetFile)
		if not ok or not raw or raw == "" then return nil end
		local ok2, data = pcall(function() return GUI:_decodeConfig(raw) end)
		if not ok2 or not data or not next(data) then return nil end
		return data
	end

