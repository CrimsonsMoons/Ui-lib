		local function currentHumanoid()
			local character = LP and LP.Character
			return character and character:FindFirstChildOfClass("Humanoid")
		end
		local value = restoreValue
		if value == nil then
			local h = currentHumanoid()
			if h then
				local ok, current = pcall(function() return h[property] end)
