			callback    = function(state)
				GUI:SetWatermarkStatsVisible(state)
			end,
		})
		GUI._cfgSyncCallbacks.watermarkStats = function(v)
			pcall(function() watermarkStatsToggle:Set(v, true) end)
		end
		S:Button({
			name        = "Reset Top Right Position",
			description = "Moves the top-right mini bar back to its default spot",
			callback    = function()
				GUI:ResetWatermarkPosition()
				GUI.notify("Top Right Mini UI", "Position reset", 2, "success")
			end,
		})

		S:Section({ name = "Info" })
		S:Label({ text = "VenturaUI v" .. Library.Version .. "  •  library-only autosaves theme + scale" })
		S:Label({ text = "Logged in as: " .. LP.Name .. "  (UserId: " .. LP.UserId .. ")" })
		S:Label({ text = "Toggle: " .. keys.toggle.Name })
		S:Divider()
		S:Button({
			name        = "Copy UserId",
			description = "Copy your Roblox UserId to clipboard",
			callback    = function()
				pcall(function() setclipboard(tostring(LP.UserId)) end)
				GUI.notify("Copied!", "UserId: " .. LP.UserId, 2, "success")
			end,
		})

		-- Sync the Settings controls with the config after all callbacks exist.
		if GUI._startupLoadedConfig then GUI:ApplyConfig(GUI._startupLoadedConfig) end
	end) -- task.defer (Settings)

	return GUI
