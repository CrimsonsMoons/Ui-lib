		GUI._cfgSyncCallbacks.responsiveScale = function(v)
			pcall(function() responsiveToggle:Set(v ~= false, true) end)
		end

		S:Info({ text = "Window drag now allows the UI to move partly outside the screen while keeping a small grab area visible." })

		S:Section({ name = "Top Right Mini UI" })
		local watermarkStatsToggle = S:Toggle({
			name        = "Show FPS / Ping",
