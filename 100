		local CONTROL_TEXT_INSET = 8

		-- Universal control API -----------------------------------------------------
		-- Every returned control can now be managed the same way from user scripts:
		-- :Get(), :Set(), :Show(), :Hide(), :Enable(), :Disable(), :Destroy(),
		-- :SetName(), :SetDescription(), :SetCallback(), :GetFrame().
		local function _universalControl(control, opts)
			control = control or {}
			opts = opts or {}
			local frame = control.frame
			control._enabled = control._enabled ~= false

			local function findLabel(names)
				if not frame then return nil end
				for _, name in ipairs(names) do
					local hit = frame:FindFirstChild(name, true)
					if hit and hit:IsA("TextLabel") then return hit end
				end
				return nil
			end

			function control:GetFrame() return self.frame end
			function control:IsVisible() return self.frame and self.frame.Visible == true or false end
			function control:SetVisible(v)
				if self.frame then self.frame.Visible = v == true end
				return self
			end
			function control:Show() return self:SetVisible(true) end
			function control:Hide() return self:SetVisible(false) end

			function control:IsEnabled() return self._enabled ~= false and self.Disabled ~= true end
			function control:SetEnabled(v)
				local enabled = v ~= false
				self._enabled = enabled
				self.Disabled = not enabled
				if type(self.SetDisabled) == "function" then
					pcall(function() self:SetDisabled(not enabled) end)
				end
				if self.frame then
					self.frame.Active = enabled
					pcall(function() tw(self.frame, {BackgroundTransparency = enabled and 0 or 0.34}, TI_FAST) end)
					for _, d in ipairs(self.frame:GetDescendants()) do
						if d:IsA("TextBox") then d.TextEditable = enabled end
						if d:IsA("GuiButton") then d.Active = enabled end
					end
				end
				return self
			end
			function control:Enable() return self:SetEnabled(true) end
			function control:Disable() return self:SetEnabled(false) end

			if type(control.Get) ~= "function" then
				function control:Get() return self.Value end
			end
			if type(control.Set) ~= "function" then
				function control:Set(v, silent)
					self.Value = v
					if not silent and type(opts.callback) == "function" then pcall(opts.callback, v) end
					pcall(function() GUI:MarkConfigDirty() end)
					return self
				end
			end

			function control:SetName(text)
				local newText = tostring(text or "")
				opts.name = newText
				local l = findLabel({"ControlTitle", "ButtonTitle", "SectionTitle"})
				if l then l.Text = newText end
				return self
			end
			function control:GetName()
				local l = findLabel({"ControlTitle", "ButtonTitle", "SectionTitle"})
				return l and l.Text or tostring(opts.name or "")
			end
			function control:SetDescription(text)
				local newText = tostring(text or "")
				opts.description = newText
				local l = findLabel({"ControlDescription", "ButtonDescription", "SectionSubtitle"})
				if l then l.Text = newText end
				return self
			end
			function control:GetDescription()
				local l = findLabel({"ControlDescription", "ButtonDescription", "SectionSubtitle"})
				return l and l.Text or tostring(opts.description or "")
			end
			function control:SetCallback(fn)
				if type(fn) == "function" then
					opts.callback = fn
					self._callback = fn
				end
				return self
			end
			function control:Destroy()
				if type(self.Clear) == "function" then pcall(function() self:Clear() end) end
				if self._dragConns then for _, c in ipairs(self._dragConns) do pcall(function() c:Disconnect() end) end end
				if self._conns then for _, c in ipairs(self._conns) do pcall(function() c:Disconnect() end) end end
				if self.frame then pcall(function() self.frame:Destroy() end) end
				return nil
			end
			return control
		end

