	function GUI:_c3ToHex(c)
		return string.format("%02X%02X%02X",
			math.floor(c.R*255+0.5), math.floor(c.G*255+0.5), math.floor(c.B*255+0.5))
	end
	function GUI:_hexToC3(h)
		h = (h or ""):gsub("#","")
		if #h < 6 then return Library.Theme.Accent end
		return Color3.fromRGB(
			tonumber(h:sub(1,2),16) or 0,
			tonumber(h:sub(3,4),16) or 0,
			tonumber(h:sub(5,6),16) or 0)
	end
	function GUI:_encodeConfig(t)
		local ok, encoded = pcall(function()
			return HttpService:JSONEncode(t or {})
		end)
		if ok and encoded then return encoded end

		-- Fallback for unusual executor environments.
		local lines = {}
		for k,v in pairs(t or {}) do
			table.insert(lines, tostring(k) .. "=" .. tostring(v))
		end
		table.sort(lines)
		return table.concat(lines, "\n")
	end

	function GUI:_decodeConfig(s)
		s = tostring(s or "")
		local ok, decoded = pcall(function()
			return HttpService:JSONDecode(s)
		end)
		if ok and type(decoded) == "table" then return decoded end

		-- Backward compatibility for old line-based saves.
		local t = {}
		for line in (s.."\n"):gmatch("([^\n]*)\n") do
			local k, v = line:match("^([^=]+)=(.*)$")
			if k and v then
				k = k:match("^%s*(.-)%s*$"); v = v:match("^%s*(.-)%s*$")
				if v == "true" then t[k] = true
				elseif v == "false" then t[k] = false
				elseif tonumber(v) then t[k] = tonumber(v)
				else t[k] = v end
			end
		end
		return t
	end

	GUI._saveQueued = false
	function GUI:_configPayload()
		-- UI-only autosave payload. No buttons/toggles/sliders from your script are saved.
		local payload = {
			accent    = GUI:_c3ToHex(Library.Theme.Accent),
			theme     = GUI._savedTheme or options.theme or "Dark",
			scale     = currentScale,
			winW      = math.floor(winW),
			winH      = math.floor(winH),
			renderW   = math.floor((MainWrap and MainWrap.AbsoluteSize.X > 0) and MainWrap.AbsoluteSize.X or select(1, getScaledWindowSize())),
			renderH   = math.floor((MainWrap and MainWrap.AbsoluteSize.Y > 0) and MainWrap.AbsoluteSize.Y or select(2, getScaledWindowSize())),
			toggleKey = keys.toggle.Name,
			miniVisible = floatingMiniAllowed and miniVisible == true or false,
			miniX = (floatingMiniAllowed and miniFrame) and miniFrame.Position.X.Offset or 0,
			miniY = (floatingMiniAllowed and miniFrame) and miniFrame.Position.Y.Offset or 0,
			watermarkStatsVisible = wmStatsVisible == true,
			watermarkX = wmFrame and wmFrame.Position.X.Offset or WM_DEFAULT_X,
			watermarkY = wmFrame and wmFrame.Position.Y.Offset or WM_DEFAULT_Y,
			watermarkScaleX = wmFrame and wmFrame.Position.X.Scale or 1,
			watermarkScaleY = wmFrame and wmFrame.Position.Y.Scale or 0,
			responsiveScale = _responsiveScaleEnabled == true,
			resizeSnap = _resizeSnapEnabled == true,
			resizeSnapMode = _resizeSnapMode,
			dragBounds = options.dragBounds == true,
		}
		return GUI:_encodeConfig(payload)
	end

	GUI._configDirty = false
	function GUI:MarkConfigDirty()
		GUI._configDirty = true
		-- Auto-save only the UI preferences file. The SaveConfig function is defined
		-- below, so this deferred call safely runs after construction finishes.
		if not GUI._configApplying and not _destroyed then
			task.defer(function()
				if not _destroyed and GUI._configDirty and type(GUI.SaveConfig) == "function" then
					GUI:SaveConfig(false)
				end
			end)
		end
		return true
	end
	function GUI:IsConfigDirty()
		return GUI._configDirty == true
	end
	function GUI:ClearConfigDirty()
		GUI._configDirty = false
		return true
	end

	function GUI:ResetConfig(profileName, applyNow)
		local data = {
			theme = options.theme or "Dark",
			accent = GUI:_c3ToHex(options.accent or Color3.fromRGB(100,150,255)),
			scale = 100,
			winW = math.floor(_defaultWinW or 820),
			winH = math.floor(_defaultWinH or 580),
			toggleKey = (options.toggleKey or Enum.KeyCode.RightControl).Name,
			watermarkStatsVisible = true,
			watermarkX = WM_DEFAULT_X,
			watermarkY = WM_DEFAULT_Y,
			watermarkScaleX = 1,
			watermarkScaleY = 0,
			responsiveScale = true,
			resizeSnap = true,
			resizeSnapMode = "center",
			dragBounds = false,
		}
		if applyNow ~= false then
			GUI:ApplyConfig(data)
		end
		GUI._loadedConfigData = data
