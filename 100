		-- ── ADVANCED LAYOUT HELPERS ─────────────────────────────────────────────
		local function makeProxyParent(parent)
			local Proxy = { _scroll = parent }
			local names = {
				"Section", "Separator", "Label", "Paragraph", "Badge", "ButtonGrid", "Image",
				"ProgressBar", "Button", "Toggle", "Slider", "Dropdown", "SearchDropdown",
				"SearchableDropdown", "FilterDropdown", "TextInput", "ColorPicker", "Keybind",
				"Warning", "Info", "Success", "Divider", "Chip", "ControlHint", "Hyperlink",
				"StatusCard", "LogConsole"
			}
			local function callTabMethod(methodName, ...)
				local fn = Tab[methodName]
				if type(fn) ~= "function" then return nil end
				local old = Tab._scroll
				Tab._scroll = parent
				local ok, result = pcall(fn, Tab, ...)
				Tab._scroll = old
				if not ok then error(result, 2) end
				return result
			end
			for _, methodName in ipairs(names) do
				Proxy[methodName] = function(_, ...)
					return callTabMethod(methodName, ...)
				end
			end
			return Proxy
		end

		local function attachAutoHeight(frame, body, layout, topPad, bottomPad, minHeight, isOpenFn)
			local function updateHeight()
				task.defer(function()
