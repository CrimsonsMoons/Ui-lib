		for _, fn in ipairs(GUI._destroyCallbacks or {}) do
			pcall(fn)
		end
		for _,c in ipairs(_connections) do pcall(function() c:Disconnect() end) end
		_connections={}
		if _mainTween then _mainTween:Cancel(); _mainTween = nil end
		if minimizeBubble then pcall(function() minimizeBubble:Destroy() end); minimizeBubble=nil end
		if _ttFrame then pcall(function() _ttFrame.Visible=false end) end
		local sw, sh = getScaledWindowSize()
		if minimized then
			minimized = false
			Nav.Visible = true; Content.Visible = true
			MainWrap.Size = UDim2.new(0, sw, 0, 34)
