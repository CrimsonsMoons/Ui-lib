	local function _styleMinimizeBubble()
		if not minimizeBubble then return end
		local accent = Library.Theme.Accent
		local themeName = tostring(GUI._savedTheme or GUI._activeTheme or "Dark")
		local themeKey = themeName:lower()
		local bg = Library.Theme.Background or Color3.fromRGB(8, 8, 12)
		local surface = Library.Theme.Surface or Color3.fromRGB(18, 18, 22)
		local hover = Library.Theme.SurfaceHover or surface
		local border = Library.Theme.BorderHover or Library.Theme.Border or accent
		local starColor = Library.Theme.TextPrimary or Color3.fromRGB(245,245,255)

		-- 5.20: every theme gets the animated orbit/star bubble. The colors are
		-- pulled from the current theme so it no longer looks like the default dark one.
		local shell = bg:Lerp(accent, themeKey == "space" and 0.18 or 0.11)
		local inner = surface:Lerp(accent, themeKey == "space" and 0.16 or 0.09)
		local top = hover:Lerp(accent, 0.28)
		local bottom = bg:Lerp(Color3.fromRGB(0,0,0), 0.28)

		minimizeBubble.BackgroundColor3 = shell
		if minimizeBubbleStroke then minimizeBubbleStroke.Color = border:Lerp(accent, 0.45) end
		if minimizeBubbleAccent then
			minimizeBubbleAccent.BackgroundColor3 = accent
			minimizeBubbleAccent.Visible = false
		end
		if minimizeBubbleGlow then
			minimizeBubbleGlow.BackgroundColor3 = accent
			minimizeBubbleGlow.BackgroundTransparency = themeKey == "space" and 0.60 or 0.68
		end
		if minimizeBubbleRing then
			minimizeBubbleRing.BackgroundColor3 = accent
			minimizeBubbleRing.BackgroundTransparency = themeKey == "space" and 0.80 or 0.84
		end
		if minimizeBubbleDot then minimizeBubbleDot.BackgroundColor3 = accent end
		if minimizeBubbleInner then
			minimizeBubbleInner.BackgroundColor3 = inner
		end
		if minimizeBubbleGradient then
			minimizeBubbleGradient.Color = ColorSequence.new({
				ColorSequenceKeypoint.new(0, top),
				ColorSequenceKeypoint.new(0.52, shell),
				ColorSequenceKeypoint.new(1, bottom),
			})
		end
		for _, child in ipairs(minimizeBubble:GetDescendants()) do
			if child.Name == "BubbleStar" then
				child.Visible = true
				child.BackgroundColor3 = starColor:Lerp(accent, 0.18)
			elseif child.Name == "ModernMarkAccentTop" or child.Name == "ModernMarkMiddle" or child.Name == "ModernMarkAccentBottom" then
				child.Visible = false
			elseif child.Name == "BubbleSpaceOrbit" then
				child.Visible = true
				local st = child:FindFirstChildOfClass("UIStroke")
				if st then
					st.Color = accent:Lerp(starColor, 0.35)
					st.Transparency = themeKey == "space" and 0.70 or 0.78
				end
			end
		end
	end

