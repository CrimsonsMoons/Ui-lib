		function Tab:Paragraph(opts)
			opts=validate({title="",text="Paragraph text here.",icon="",color=nil},opts)
			local bodyText=tostring(opts.text or "")
			local titleText=tostring(opts.title or "")
			local hasTitle=titleText ~= ""
			local widthGuess=math.max(260, (Content.AbsoluteSize.X > 0 and Content.AbsoluteSize.X or 540) - 52)
			local bodyH=math.max(18, math.ceil(textHeight(bodyText,widthGuess,12,Enum.Font.SourceSans)) + 4)
			local totalH=bodyH + (hasTitle and 25 or 0) + 22
			local f=base("Paragraph", totalH)
			pad(f,12,14,12,14)
			local x=0
			if opts.icon ~= "" then
				local ic=lbl(f,tostring(opts.icon),16,Library.Theme.Accent,FONT_UI_BOLD,Enum.TextXAlignment.Center)
				ic.Size=UDim2.new(0,24,0,24); ic.Position=UDim2.new(0,0,0,0)
				x=32
