	local function _applyResponsiveScale(forceSnap)
		if not _responsiveScaleEnabled or _destroyed or not MainWrap or not MainWrap.Parent then return end
		WIN_MAX_W, WIN_MAX_H = getViewportLimit()
		local sw, sh = applyWindowScale(false, minimized and 34 or nil)
		local cam = workspace.CurrentCamera
		local vps = cam and cam.ViewportSize or Vector2.new(1280, 720)
		local viewportChanged = (math.abs(vps.X - _lastViewportSize.X) > 1 or math.abs(vps.Y - _lastViewportSize.Y) > 1)
		_lastViewportSize = vps

		if _resizeSnapEnabled and (forceSnap == true or viewportChanged) then
			_snapMainToViewport(sw, sh)
			_snapSmallUIsToViewport()
		else
			local x = MainWrap.Position.X.Offset ~= 0 and MainWrap.Position.X.Offset or (vps.X * 0.5)
			local y = MainWrap.Position.Y.Offset ~= 0 and MainWrap.Position.Y.Offset or (vps.Y * 0.5)
			MainWrap.Position = UDim2.new(0, x, 0, y)
		end
	end
