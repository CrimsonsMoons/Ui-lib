function Library:new(options)
	options=validate({
		name            = "Ventura UI",
		subtitle        = nil,
		toggleKey       = Enum.KeyCode.RightControl,
		minimizeKey     = Enum.KeyCode.Unknown,
		loadingTime     = 1.5,
		accent          = nil,
		theme           = nil,
		configProfile   = "Default",
		profile         = nil,
		autoLoad        = true,
		autoLoadConfig  = true,
		configAutoLoad  = true,
		onClose         = nil,
		watermark       = nil,
		watermarkStats  = true,    -- show FPS + ping in the top-right watermark bar
		destroyOnRespawn= false,
		reconnectOnRespawn = true,
		reconnectDelay   = 0.85,
		keyEnabled      = false,
		key             = nil,
		keyLink         = nil,
		onKeySuccess    = nil,
		onKeyFail       = nil,
		aiEnabled       = false,   -- set true for a free built-in AI assistant (no key needed)
		floatingMiniUI  = false,   -- legacy separate top-right HUD; off by default
		miniUI          = nil,     -- alias: true only if you intentionally want the old top-right HUD
		miniTitle       = "VENTURA",
		responsiveScale = true,    -- auto-fit/rescale when the Roblox window/screen size changes
		resizeSnap      = true,    -- when the Roblox window changes size, snap UI back to visible spots
		resizeSnapMode  = "center", -- main window snap mode: "center" or "corner"
		looseDragBounds = false,   -- legacy option; drag borders are removed in 5.8
		dragBounds      = false,   -- false = no screen-edge clamping at all
		offscreenGrip   = 0,       -- legacy option kept for compatibility
		dragOutMultiplier = 1.0,  -- normal 1:1 dragging by default
		minimizeBubbleIcon = nil, -- kept for compatibility; modern bubble no longer renders icon text
		toggleCreatesBubble = false, -- minimize UI removed: toggle key only shows / hides the window
		goodbyeNotification = false, -- off by default so closing stops activity immediately
	}, options)

	if options.theme and Library.Themes and Library.Themes[options.theme] then
		for k,v in pairs(Library.Themes[options.theme]) do
			if k ~= "UserBox" then Library.Theme[k] = v end
		end
	end
	if options.accent then Library.Theme.Accent=options.accent end

	destroyExistingVenturaGUI()

	local keys            = {toggle=options.toggleKey, minimize=options.minimizeKey}
	local keybindListening= false
	local currentScale    = 100
	local _destroyed      = false
	local _connections    = {}

	local function getOffscreenGrip(defaultGrip)
		-- 5.8 removes drag borders entirely. This is kept so older scripts using
		-- SetOffscreenGrip/GetOffscreenGrip do not error.
		local g = tonumber(options.offscreenGrip) or defaultGrip or 0
		return math.max(0, math.floor(g + 0.5))
	end

	local function getDragOutMultiplier()
		return math.clamp(tonumber(options.dragOutMultiplier) or 1, 0.1, 5)
	end

	local function _dragBordersEnabled()
		return options.dragBounds == true
	end

	local function _offsetPosition(pos, fallbackX, fallbackY)
		local cam = workspace.CurrentCamera
		local vp = cam and cam.ViewportSize or Vector2.new(1280, 720)
		if not pos then return UDim2.new(0, fallbackX or 14, 0, fallbackY or 14) end
		local x = pos.X.Offset
		local y = pos.Y.Offset
		if pos.X.Scale ~= 0 then x = math.floor(vp.X * pos.X.Scale + pos.X.Offset + 0.5) end
		if pos.Y.Scale ~= 0 then y = math.floor(vp.Y * pos.Y.Scale + pos.Y.Offset + 0.5) end
		return UDim2.new(0, x, 0, y)
	end

	local GUI = {CurrentTab=nil, _tabs={}, _open=true, _accentObjects={}, _keybindWidgets={}, _activeKeybind=nil, _configControls={}, _toggleControls={}, _reconnectControls={}, _reconnectCallbacks={}, _loadedConfigData=nil, _configApplying=false, _destroyCallbacks={}, _cleanupCallbacks={}, _trackedProperties={}, _trackedHumanoidProperties={}, _trackedInstances={}, _activityStopped=false, _reconnectEnabled=(options.reconnectOnRespawn ~= false), _reconnectDelay=tonumber(options.reconnectDelay) or 0.85, _respawnToken=0}

	-- Top-right watermark / mini bar stats state
	local wmFrame, wmLbl, wmBaseText
	local wmStatsVisible = true
	-- 5.18: stats bar defaults to top-right so it stays clear of Roblox top-left UI.
	local WM_DEFAULT_X, WM_DEFAULT_Y = -14, 14

	-- Predeclared here so viewport-resize snapping can also recover the minimized restore bubble.
	local minimizeBubble

	-- Config ID / flag helpers -------------------------------------------------
	-- Use opts.flag / opts.configId / opts.configID / opts.saveId / opts.id on controls.
	-- Example: Tab:Toggle({ name="Auto Farm", flag="autoFarm" })
	local function _trim(s)
		return tostring(s or ""):gsub("^%s+", ""):gsub("%s+$", "")
	end
	local function _controlConfigId(opts)
		local id = opts and (opts.configId or opts.configID or opts.flag or opts.saveId or opts.config or opts.id)
		id = _trim(id or "")
		return id ~= "" and id or nil
	end
	local function _cfgKey(id)
		local safe = _trim(id):gsub("[^%w_%-%.]", function(ch)
			return string.format("_%02X", string.byte(ch))
		end)
		return "control." .. safe
	end
	local function _cfgEsc(sv)
		sv = tostring(sv or "")
		sv = sv:gsub("%%", "%%25"):gsub("\n", "%%0A"):gsub("\r", "%%0D"):gsub("|", "%%7C"):gsub("=", "%%3D")
		return sv
	end
	local function _cfgUnesc(sv)
		sv = tostring(sv or "")
		sv = sv:gsub("%%3D", "="):gsub("%%7C", "|"):gsub("%%0D", "\r"):gsub("%%0A", "\n"):gsub("%%25", "%%")
		return sv
	end
	local function _cfgColorToHex(c)
		return string.format("%02X%02X%02X", math.floor(c.R*255+0.5), math.floor(c.G*255+0.5), math.floor(c.B*255+0.5))
	end
	local function _cfgHexToColor(hex)
		hex = tostring(hex or ""):gsub("#", "")
		if #hex ~= 6 or not hex:match("^[%da-fA-F]+$") then return nil end
		return Color3.fromRGB(tonumber(hex:sub(1,2),16) or 0, tonumber(hex:sub(3,4),16) or 0, tonumber(hex:sub(5,6),16) or 0)
	end
	local function _cfgEncodeValue(v)
		if typeof(v) == "Color3" then return "__c3:" .. _cfgColorToHex(v) end
		if typeof(v) == "EnumItem" then return "__key:" .. tostring(v.Name) end
		if type(v) == "table" then
			local parts = {}
			for _, x in ipairs(v) do table.insert(parts, _cfgEsc(x)) end
			return "__tbl:" .. table.concat(parts, "|")
		end
		if type(v) == "string" then return "__str:" .. _cfgEsc(v) end
		if type(v) == "boolean" then return v and "__bool:true" or "__bool:false" end
		if type(v) == "number" then return "__num:" .. tostring(v) end
		return "__str:" .. _cfgEsc(tostring(v or ""))
	end
	local function _cfgDecodeValue(v)
		if type(v) ~= "string" then return v end
		if v:sub(1,6) == "__str:" then return _cfgUnesc(v:sub(7)) end
		if v:sub(1,6) == "__num:" then return tonumber(v:sub(7)) or 0 end
		if v:sub(1,7) == "__bool:" then return v:sub(8) == "true" end
		if v:sub(1,6) == "__key:" then return v:sub(7) end
		if v:sub(1,6) == "__c3:" then return _cfgHexToColor(v:sub(7)) end
		if v:sub(1,6) == "__tbl:" then
			local out = {}
			local body = v:sub(7)
			if body ~= "" then
				for part in (body .. "|"):gmatch("(.-)|") do table.insert(out, _cfgUnesc(part)) end
			end
			return out
		end
		return v
	end
	local function _applyConfigValueToControl(control, raw, fireCallback)
		if raw == nil or not control or type(control.Set) ~= "function" then return end
		local decoded = _cfgDecodeValue(raw)
		GUI._configApplying = true
		local ok, err = pcall(function()
			-- fireCallback=true keeps script variables synced when auto-loading saved controls.
			control:Set(decoded, not fireCallback)
		end)
		GUI._configApplying = false
		if not ok then warn("[VenturaUI] Failed applying config control: " .. tostring(err)) end
	end
	local function _registerConfigControl(control, opts, kind)
		-- Library-only build: the old profile config system is disabled.
		-- Controls can still use flags/ids for your own scripts, but VenturaUI will not
		-- auto-save or auto-load gameplay/script control values anymore.
		return control
	end

	-- Respawn reconnect helpers --------------------------------------------------
	-- Controls that affect Character/Humanoid state can re-fire after death so
	-- active features do not silently stop working on the new character.
	local function _registerReconnectControl(control, opts, kind)
		if not control then return control end
		opts = opts or {}
		local defaultReconnect = (kind == "toggle" or kind == "slider")
		local shouldReconnect = (opts.reconnect == true) or (opts.reconnectOnRespawn == true)
		if defaultReconnect and opts.reconnect ~= false and opts.reconnectOnRespawn ~= false then
			shouldReconnect = true
		end
		control._reconnectKind = kind or "generic"
		control._reconnectOnRespawn = shouldReconnect == true
		control._callback = control._callback or opts.callback
		if control._reconnectOnRespawn then
			table.insert(GUI._reconnectControls, control)
		end
		return control
	end

	local function _safeControlValue(control)
		if control and type(control.Get) == "function" then
			local ok, value = pcall(function() return control:Get() end)
			if ok then return value end
		end
		return control and control.Value
	end

	local function _runReconnect(reason)
		if _destroyed or GUI._activityStopped or GUI._reconnectEnabled == false then return false end
		local character = LP.Character
		if not character then return false end
		local humanoid = character:FindFirstChildOfClass("Humanoid") or character:WaitForChild("Humanoid", 5)

		-- Let scripts rebuild character-bound effects/connections first.
		for _, callback in ipairs(GUI._reconnectCallbacks or {}) do
			if type(callback) == "function" then
				pcall(callback, character, humanoid, reason or "manual")
			end
		end

		-- Re-apply active control callbacks. This fixes sliders like WalkSpeed and
		-- toggles like noclip/auras that need to bind to the new character.
		for i = #GUI._reconnectControls, 1, -1 do
			local control = GUI._reconnectControls[i]
			if not control or (control.frame and not control.frame.Parent) then
				table.remove(GUI._reconnectControls, i)
			elseif control._reconnectOnRespawn ~= false then
				local value = _safeControlValue(control)
				local kind = tostring(control._reconnectKind or "generic")
				local callback = control._callback
				if type(callback) == "function" then
					if kind == "toggle" then
						if value == true then pcall(callback, true, "respawn", character, humanoid) end
					elseif kind == "slider" then
						pcall(callback, value, "respawn", character, humanoid)
					elseif control._forceReconnectCallback == true then
						pcall(callback, value, "respawn", character, humanoid)
					end
				end
			end
		end
		return true
	end

	local function _scheduleReconnect(reason, delayOverride)
		if _destroyed or GUI._activityStopped or GUI._reconnectEnabled == false then return end
		GUI._respawnToken = (GUI._respawnToken or 0) + 1
		local token = GUI._respawnToken
		task.delay(tonumber(delayOverride) or GUI._reconnectDelay or 0.85, function()
			if token ~= GUI._respawnToken then return end
			_runReconnect(reason or "respawn")
		end)
	end

	local function track(c) table.insert(_connections,c) end
	local function regAccent(obj, prop)
		if obj then
			pcall(function() obj:SetAttribute("VenturaAccent", true) end)
			table.insert(GUI._accentObjects, {obj=obj, prop=prop or "BackgroundColor3"})
		end
		return obj
	end
	local function applyAccentToRegistered(color)
		Library.Theme.Accent = color
		for i = #GUI._accentObjects, 1, -1 do
			local item = GUI._accentObjects[i]
			if item.obj and item.obj.Parent then
				pcall(function() item.obj[item.prop] = color end)
			else
				table.remove(GUI._accentObjects, i)
			end
		end
		pcall(function()
			if GUI._sg then
				for _, obj in ipairs(GUI._sg:GetDescendants()) do
					if obj.Name == "TogglePill" and obj:GetAttribute("VenturaOn") == true then
					obj.BackgroundColor3 = color
					local st = obj:FindFirstChildOfClass("UIStroke")
					if st then st.Color = color end
					end
				end
			end
