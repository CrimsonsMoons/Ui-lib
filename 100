		_spaceStars = {}

		local starCount = 70
		for i = 1, starCount do
			local dot = Instance.new("Frame", _spaceLayer)
			dot.Name = "Star"
			dot.BorderSizePixel = 0
			dot.BackgroundColor3 = i % 7 == 0 and Color3.fromRGB(135, 190, 255) or Color3.fromRGB(240, 248, 255)
			dot.BackgroundTransparency = (i % 5 == 0) and 0.15 or 0.35
			dot.ZIndex = 0
			local size = (i % 11 == 0) and 3 or ((i % 3 == 0) and 2 or 1)
			dot.Size = UDim2.new(0, size, 0, size)
			corner(dot, size)
			local data = {
				obj = dot,
				x = math.random(),
				y = math.random(),
				speed = 0.018 + math.random() * 0.055,
				drift = (math.random() - 0.5) * 0.018,
				pulse = math.random() * math.pi * 2,
				baseTransparency = dot.BackgroundTransparency,
			}
			table.insert(_spaceStars, data)
		end
		return _spaceLayer
	end

	local function _stepSpaceStars(dt)
		if not _spaceEnabled or not _spaceLayer or not _spaceLayer.Parent then return end
		GUI._spaceClock = (GUI._spaceClock or 0) + dt
		local w = math.max(_spaceLayer.AbsoluteSize.X, 1)
		local h = math.max(_spaceLayer.AbsoluteSize.Y, 1)
		local accent = Library.Theme.Accent or Color3.fromRGB(115,185,255)
		local text = Library.Theme.TextPrimary or Color3.fromRGB(240,248,255)
		local style = tostring(GUI._spaceStyle or "stars"):lower()
		for i, star in ipairs(_spaceStars) do
			local o = star.obj
			if o and o.Parent then
				local xDrift = star.drift
				local ySpeed = star.speed
				if style == "matrix" or style == "toxic" then
					ySpeed = ySpeed * 1.65
					xDrift = xDrift * 0.25
				elseif style == "embers" or style == "inferno" then
					ySpeed = -ySpeed * 1.10
					xDrift = xDrift * 1.80
				elseif style == "aurora" then
					xDrift = xDrift + math.sin(GUI._spaceClock * 0.8 + i) * 0.035
					ySpeed = ySpeed * 0.42
				elseif style == "ocean" then
					xDrift = xDrift + math.sin(GUI._spaceClock * 1.25 + star.y * 5) * 0.025
					ySpeed = ySpeed * 0.65
				elseif style == "galaxy" or style == "void" then
					xDrift = xDrift + math.sin(GUI._spaceClock * 0.7 + i * 0.41) * 0.018
					ySpeed = ySpeed * 0.58
				elseif style == "sakura" then
					xDrift = xDrift + math.sin(GUI._spaceClock * 1.4 + i) * 0.045
					ySpeed = ySpeed * 0.55
				elseif style == "luxury" then
					ySpeed = ySpeed * 0.35
					xDrift = xDrift * 0.45
				end

				star.y = star.y + ySpeed * dt
				star.x = star.x + xDrift * dt
				if star.y > 1.04 then
					star.y = -0.04
					star.x = math.random()
				elseif star.y < -0.05 then
					star.y = 1.04
					star.x = math.random()
				end
				if star.x > 1.04 then star.x = -0.04 elseif star.x < -0.04 then star.x = 1.04 end
				star.pulse = star.pulse + dt * (style == "toxic" and 4.1 or 2.2)
				o.Position = UDim2.new(0, math.floor(star.x * w + 0.5), 0, math.floor(star.y * h + 0.5))
				o.BackgroundTransparency = math.clamp(star.baseTransparency + math.sin(star.pulse) * 0.18, 0.05, 0.82)
				if style == "embers" or style == "inferno" then
					o.BackgroundColor3 = Color3.fromRGB(255, 150 + (i % 3) * 25, 65):Lerp(accent, 0.28)
				elseif style == "toxic" or style == "matrix" then
					o.BackgroundColor3 = Color3.fromRGB(170, 255, 85):Lerp(accent, 0.20)
				elseif style == "sakura" then
					o.BackgroundColor3 = Color3.fromRGB(255, 170, 220):Lerp(accent, 0.30)
				elseif style == "luxury" then
					o.BackgroundColor3 = Color3.fromRGB(255, 220, 120):Lerp(accent, 0.22)
				else
					o.BackgroundColor3 = text:Lerp(accent, (i % 5) * 0.12)
				end
			end
		end
	end

	local function _setSpaceBackground(enabled, style)
		enabled = enabled == true
		_spaceEnabled = enabled
		GUI._spaceStyle = tostring(style or GUI._spaceStyle or "stars")
