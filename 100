	-- ══════════════════════════════════════════════════════════════════════
	-- Config save / load
	-- ══════════════════════════════════════════════════════════════════════
	local _cfgFolder = "VenturaUI"
	local _cfgBaseName = options.name:gsub("[^%w%-%_]", "_")
	local _cfgProfileFolder = _cfgFolder .. "/" .. _cfgBaseName
	-- Library-only auto-save: one tiny UI settings file per window name.
	-- This stores UI-only preferences such as theme, accent, scale, and window size.
	local _cfgProfileIndexFile = _cfgProfileFolder .. "/profiles.index" -- legacy compatibility only
	local _cfgAutoLoadFile = _cfgProfileFolder .. "/autoload.profile" -- legacy compatibility only
	local _cfgAutoLoadEnabledFile = _cfgProfileFolder .. "/autoload.enabled" -- legacy compatibility only
	local _cfgProfileDeletedFile = _cfgProfileFolder .. "/profiles.deleted" -- legacy compatibility only

	local function _profileSanitize(name)
		name = _trim(name or "")
		if name == "" then name = "Default" end
		return name
	end

	local function _profileFileName(name)
		local safe = _profileSanitize(name):gsub("[^%w%-%_%.]", "_")
		if safe == "" then safe = "Default" end
		return safe .. ".json"
	end

	local _cfgProfile = "AutoUI"
	local _explicitProfileProvided = false
	local _cfgFile = _cfgProfileFolder .. "/ui-settings.json"
	local _autoLoadEnabled = true

	local function _setConfigProfileInternal(name)
		-- Profiles are disabled in this build. Keep this function only so older
		-- scripts that call SetConfigProfile do not error.
		_cfgProfile = "AutoUI"
		_cfgFile = _cfgProfileFolder .. "/ui-settings.json"
		return _cfgProfile
	end

	local function _ensureConfigFolders()
		if not hasFileAPI() then return false end
		ensureFolder(_cfgFolder)
		ensureFolder(_cfgProfileFolder)
		return true
	end

	local function _readPlainFile(path)
		if not hasFileAPI() then return nil end
		local okExists, exists = pcall(isfile, path)
		if not okExists or not exists then return nil end
		local ok, raw = pcall(readfile, path)
		if not ok or raw == nil then return nil end
		return tostring(raw)
	end

	local function _writePlainFile(path, value)
		if not hasFileAPI() then return false end
		_ensureConfigFolders()
		local ok, err = pcall(function() writefile(path, tostring(value or "")) end)
		if not ok then warn("[VenturaUI] Config meta save failed: " .. tostring(err)) end
		return ok
	end


	local function _readDeletedProfiles()
		local deleted = {}
		local raw = _readPlainFile(_cfgProfileDeletedFile)
		if raw and raw ~= "" then
			for line in (raw .. "\n"):gmatch("([^\n]*)\n") do
				local name = _profileSanitize(_cfgUnesc(_trim(line)))
				if name ~= "" and name:lower() ~= "default" then
					deleted[name:lower()] = name
				end
			end
		end
		return deleted
	end

	local function _writeDeletedProfiles(deleted)
		if not hasFileAPI() then return false end
		local lines = {}
		local seen = {}
		for _, name in pairs(deleted or {}) do
			name = _profileSanitize(name)
			local key = name:lower()
			if name ~= "" and key ~= "default" and not seen[key] then
				seen[key] = true
				table.insert(lines, _cfgEsc(name))
			end
		end
		table.sort(lines, function(a, b) return a:lower() < b:lower() end)
		return _writePlainFile(_cfgProfileDeletedFile, table.concat(lines, "\n"))
	end

	local function _isProfileDeleted(name)
		name = _profileSanitize(name)
		if name:lower() == "default" then return false end
		return _readDeletedProfiles()[name:lower()] ~= nil
	end

	local function _markProfileDeleted(name)
		name = _profileSanitize(name)
		if name:lower() == "default" then return false end
		local deleted = _readDeletedProfiles()
		deleted[name:lower()] = name
		return _writeDeletedProfiles(deleted)
	end

	local function _unmarkProfileDeleted(name)
		name = _profileSanitize(name)
		if name:lower() == "default" then return true end
		local deleted = _readDeletedProfiles()
		deleted[name:lower()] = nil
		return _writeDeletedProfiles(deleted)
	end

	local function _readAutoLoadEnabled()
		local raw = _readPlainFile(_cfgAutoLoadEnabledFile)
		if raw == nil or raw == "" then return _autoLoadEnabled end
		raw = _trim(raw):lower()
		return raw == "true" or raw == "1" or raw == "yes" or raw == "on"
	end

	local function _writeAutoLoadEnabled(enabled)
		_autoLoadEnabled = enabled == true
		return _writePlainFile(_cfgAutoLoadEnabledFile, _autoLoadEnabled and "true" or "false")
	end

	local function _readAutoLoadProfile()
		if not _readAutoLoadEnabled() then return nil end
		local raw = _readPlainFile(_cfgAutoLoadFile)
		if raw == nil or raw == "" then return nil end
		return _profileSanitize(_cfgUnesc(_trim(raw)))
	end

	local function _writeAutoLoadProfile(profile)
		if not _autoLoadEnabled then return false end
		return _writePlainFile(_cfgAutoLoadFile, _cfgEsc(_profileSanitize(profile or _cfgProfile)))
	end

	local function _uniqueSortedProfiles(list)
		local deleted = _readDeletedProfiles()
		local seen, out = {}, {}
		local function add(name)
			name = _profileSanitize(name)
			local key = name:lower()
			if key ~= "default" and deleted[key] then return end
			if not seen[key] then seen[key] = true; table.insert(out, name) end
		end
		add("Default")
		add(_cfgProfile)
		for _, name in ipairs(list or {}) do add(name) end
		table.sort(out, function(a,b) return a:lower() < b:lower() end)
		return out
	end

	local function _readProfileIndex()
		local profiles = {"Default", _cfgProfile}
		if hasFileAPI() then
			local okExists, exists = pcall(isfile, _cfgProfileIndexFile)
			if okExists and exists then
				local ok, raw = pcall(readfile, _cfgProfileIndexFile)
				if ok and raw then
					for line in (raw .. "\n"):gmatch("([^\n]*)\n") do
						line = _cfgUnesc(_trim(line))
						if line ~= "" then table.insert(profiles, line) end
					end
				end
			end
			-- Some executors support listfiles; use it when available but never require it.
			if type(listfiles) == "function" then
				pcall(function()
					for _, file in ipairs(listfiles(_cfgProfileFolder)) do
						local normalized = tostring(file):gsub("\\", "/")
						local base = normalized:match("([^/]+)%.json$")
						if base and base ~= "" then table.insert(profiles, base) end
					end
				end)
			end
		end
		return _uniqueSortedProfiles(profiles)
	end

	local function _writeProfileIndex(list)
		if not hasFileAPI() then return false end
		_ensureConfigFolders()
		local profiles = _uniqueSortedProfiles(list or {})
		local lines = {}
		for _, name in ipairs(profiles) do table.insert(lines, _cfgEsc(name)) end
		local ok, err = pcall(function() writefile(_cfgProfileIndexFile, table.concat(lines, "\n")) end)
		if not ok then warn("[VenturaUI] Profile index save failed: " .. tostring(err)) end
		return ok
	end

	local function _addProfileToIndex(name)
		name = _profileSanitize(name)
		_unmarkProfileDeleted(name)
		local profiles = _readProfileIndex()
		table.insert(profiles, name)
		_writeProfileIndex(profiles)
		return _uniqueSortedProfiles(profiles)
	end

	-- Auto-load the last selected/saved profile on startup unless the script explicitly picked one.
	_autoLoadEnabled = _readAutoLoadEnabled()
	if _autoLoadEnabled and not _explicitProfileProvided then
		local autoProfile = _readAutoLoadProfile()
		if autoProfile then
			_setConfigProfileInternal(autoProfile)
		end
	end


	
