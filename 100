		for _, control in ipairs(GUI._toggleControls or {}) do
			if control and control._autoStopOnDestroy ~= false then
				local ok, isOn = pcall(function() return control:Get() end)
				if ok and isOn == true then
					if control._stopForDestroy then
						pcall(function() control:_stopForDestroy() end)
					else
						pcall(function() control:Set(false, true) end)
						if control._callback then pcall(control._callback, false) end
					end
				end
			end
		end
