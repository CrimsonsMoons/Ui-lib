			bl.Size=UDim2.new(1,-x,0,bodyH); bl.Position=UDim2.new(0,x,0,y)
			local function resize()
				task.defer(function()
					if not bl.Parent then return end
					local available=math.max(120, bl.AbsoluteSize.X)
					local h=math.max(18, math.ceil(textHeight(bl.Text,available,12,Enum.Font.SourceSans)) + 4)
					bl.Size=UDim2.new(1,-x,0,h)
					f.Size=UDim2.new(1,0,0,h + y + 22)
				end)
			end
			bl:GetPropertyChangedSignal("TextBounds"):Connect(resize)
			resize()
			return f
		end
		function Tab:Badge(opts)
			opts=validate({text="NEW", color=nil, textColor=nil},opts)
			local bgCol  = opts.color     or Library.Theme.Accent
