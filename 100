	-- Scale helper: winW/winH stay as the BASE logical size, currentScale is applied only when rendering.
	-- This fixes configs where scale saved correctly but the actual window reopened at the unscaled size.
	local function getScaledWindowSize(heightOverride)
		WIN_MAX_W, WIN_MAX_H = getViewportLimit()
		local scale = math.clamp(tonumber(currentScale) or 100, 50, 200) / 100
		local scaledW = math.clamp(math.floor((tonumber(winW) or 820) * scale + 0.5), WIN_MIN_W, WIN_MAX_W)
		if heightOverride then
			-- Titlebar/minimized height must NOT be multiplied by UI scale.
			return scaledW, tonumber(heightOverride) or 34
		end
		local scaledH = math.clamp(math.floor((tonumber(winH) or 580) * scale + 0.5), WIN_MIN_H, WIN_MAX_H)
		return scaledW, scaledH
	end

	local function applyWindowScale(animated, heightOverride)
		local sw, sh = getScaledWindowSize(heightOverride)
		local target = { Size = UDim2.new(0, sw, 0, sh) }
		if animated then
			tw(MainWrap, target, TI_SLOW)
		else
			MainWrap.Size = target.Size
		end
		-- 5.8: no drag borders. Scale changes keep the current position exactly as-is.
		-- If a script explicitly enables dragBounds=true, old clamping can be added by user code.
		return sw, sh
	end

