	local function _readPing()
		local ping
		local function pullStat(item)
			if not item then return nil end
			local value
			pcall(function()
				if item.GetValue then value = item:GetValue() end
			end)
			if value == nil then
				pcall(function()
					if item.GetValueString then value = item:GetValueString() end
				end)
			end
			if type(value) == "string" then
				value = value:match("[%d%.]+")
			end
			return tonumber(value)
		end

		pcall(function()
			local network = Stats:FindFirstChild("Network")
			local server = network and network:FindFirstChild("ServerStatsItem")
			ping = pullStat(server and (server:FindFirstChild("Data Ping") or server:FindFirstChild("Ping")))
		end)
		if not ping then
			pcall(function()
				local perf = Stats:FindFirstChild("PerformanceStats")
				ping = pullStat(perf and (perf:FindFirstChild("Ping") or perf:FindFirstChild("Network Ping")))
			end)
		end
		if not ping then
			pcall(function()
				local network = Stats:FindFirstChild("Network")
				for _, obj in ipairs(network and network:GetDescendants() or {}) do
					if not ping and obj.Name:lower():find("ping", 1, true) then
						ping = pullStat(obj)
					end
				end
			end)
		end

		ping = tonumber(ping) or 0
		-- Some stat objects report seconds; most report milliseconds.
		if ping > 0 and ping < 1 then ping = ping * 1000 end
		return math.clamp(math.floor(ping + 0.5), 0, 9999)
	end

	local function _miniColorForFPS(fps)
		fps = tonumber(fps) or 0
		if fps >= 55 then return Color3.fromRGB(80, 220, 130) end
		if fps >= 35 then return Color3.fromRGB(235, 190, 70) end
		return Color3.fromRGB(235, 85, 85)
	end
	local function _miniColorForPing(ping)
		ping = tonumber(ping) or 0
		if ping <= 90 then return Color3.fromRGB(80, 220, 130) end
		if ping <= 160 then return Color3.fromRGB(235, 190, 70) end
		return Color3.fromRGB(235, 85, 85)
	end

