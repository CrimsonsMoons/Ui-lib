	local function _runTrackedPropertyRestores()
		for i = #GUI._trackedProperties, 1, -1 do
			local item = GUI._trackedProperties[i]
			if item and item.object and item.property ~= nil then
				pcall(function()
					item.object[item.property] = item.value
				end)
			end
		end
		local character = LP and LP.Character
		local humanoid = character and character:FindFirstChildOfClass("Humanoid")
		if humanoid then
			for i = #GUI._trackedHumanoidProperties, 1, -1 do
				local item = GUI._trackedHumanoidProperties[i]
