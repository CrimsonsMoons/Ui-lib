	local function _makeSpaceLayer()
		if _spaceLayer and _spaceLayer.Parent then return _spaceLayer end
		_spaceLayer = Instance.new("Frame", Main)
		_spaceLayer.Name = "SpaceStarBackground"
		_spaceLayer.BackgroundTransparency = 1
		_spaceLayer.BorderSizePixel = 0
