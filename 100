			end
		end, "Humanoid." .. tostring(property))
		return function()
			for i, v in ipairs(GUI._trackedHumanoidProperties) do
				if v == item then table.remove(GUI._trackedHumanoidProperties, i); break end
			end
			if cleanup then cleanup() end
