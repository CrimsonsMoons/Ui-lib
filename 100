			Groupbox=true, CollapsibleSection=true, StatusCard=true, LogConsole=true,
			InputBox=true, DropdownSearchBox=true, LoaderPanel=true, UserBox=true, FloatingMiniHUD=true,
			TextButton=true,
		}
		local bgCards = {
			DropdownValue=true, SearchValue=true, DropdownList=true, SearchDropdownList=true,
			SliderTrack=true, SliderValuePill=true, SliderThumbCore=true, TogglePill=true, InputBox=true,
			DDHeader=true, ResizeHandle=true, ThemePreview=true, AccentPreviewBox=true, LogScroll=true,
		}
		for _, obj in ipairs(SG:GetDescendants()) do
			pcall(function()
				local n = obj.Name
				if obj:IsA("UIStroke") then
					if obj:GetAttribute("VenturaAccent") == true then
						obj.Color = accent
					else
						obj.Color = border
					end
				elseif obj:IsA("Frame") or obj:IsA("TextButton") then
					if obj:IsA("TextButton") and obj.BackgroundTransparency < 0.95 and n ~= "MinimizeRestoreCircle" then obj.BackgroundColor3 = surface end
					if surfaceCards[n] then obj.BackgroundColor3 = surface end
					if bgCards[n] then obj.BackgroundColor3 = background end
					if n == "TogglePill" then
						obj.BackgroundColor3 = obj:GetAttribute("VenturaOn") == true and accent or background
					end
					if n == "SliderFill" or n == "SliderThumbGlow" or n == "TopAccentSheen" or n == "OuterAccentRing" or n == "StatusDot" or n:find("Accent") then
						if obj:GetAttribute("VenturaNoTheme") ~= true then obj.BackgroundColor3 = accent end
					end
				elseif obj:IsA("TextLabel") or obj:IsA("TextBox") then
					if n == "ControlTitle" or n == "ButtonTitle" or n == "ParagraphTitle" or n == "SliderValueText" or n == "TextBox" then
						obj.TextColor3 = textPrimary
					elseif n == "ControlDescription" or n == "ButtonDescription" or n == "ParagraphBody" or n == "MiniTitle" then
						obj.TextColor3 = textSecondary
					elseif n == "StateText" then
						obj.TextColor3 = textSecondary
					end
					if obj:IsA("TextBox") then obj.PlaceholderColor3 = textDisabled end
				elseif obj:IsA("ImageLabel") or obj:IsA("ImageButton") then
					if n:find("Icon") or n:find("Arrow") then obj.ImageColor3 = textSecondary end
				end
			end)
		end
		applyAccentToRegistered(accent)
	end

	function GUI:_rgbTuple(color)
		if typeof(color) ~= "Color3" then return nil end
		return math.floor(color.R * 255 + 0.5), math.floor(color.G * 255 + 0.5), math.floor(color.B * 255 + 0.5)
	end

	function GUI:_findAccentPresetFromColor(color)
		if typeof(color) ~= "Color3" then return "Custom" end
		local r, g, b = GUI:_rgbTuple(color)
		for name, preset in pairs(Library.Accents) do
			local pr, pg, pb = GUI:_rgbTuple(preset)
			if r == pr and g == pg and b == pb then
				return name
			end
		end
		return "Custom"
	end

	function GUI:_syncAccentSettings(color, presetName)
		if typeof(color) ~= "Color3" then color = Library.Theme.Accent end
		local name = presetName or GUI:_findAccentPresetFromColor(color)
		GUI._activeAccentPreset = name
		if GUI._cfgSyncCallbacks and GUI._cfgSyncCallbacks.accent then
			pcall(GUI._cfgSyncCallbacks.accent, color)
		end
		if GUI._cfgSyncCallbacks and GUI._cfgSyncCallbacks.accentPreset then
			pcall(GUI._cfgSyncCallbacks.accentPreset, name)
		end
	end

	function GUI:_applyTheme(val)
		local t = Library.Themes[val]; if not t then return false end
		GUI._savedTheme = val
		for k,v in pairs(t) do
			if k ~= "UserBox" and k ~= "Accent" and typeof(v) == "Color3" then Library.Theme[k] = v end
		end
		_setSpaceBackground(t.Stars == true or t.Animated == true or tostring(val) == "Space", t.AnimationStyle or tostring(val):lower())
		local accentPreset = t.AccentPreset
		local themeAccent = (accentPreset and Library.Accents[accentPreset]) or t.Accent
		if typeof(themeAccent) == "Color3" then
			Library.Theme.Accent = themeAccent
			applyAccentToRegistered(themeAccent)
			GUI._activeAccentPreset = accentPreset or GUI:_findAccentPresetFromColor(themeAccent)
		end
		local surfaceNames = {Button=true, Toggle=true, Slider=true, Dropdown=true, SearchDropdown=true, Paragraph=true, ProgressBar=true, ColorPicker=true, Keybind=true, TextInput=true, Groupbox=true, CollapsibleSection=true, StatusCard=true, LogConsole=true, Warning=false, Info=false, Success=false}
		local bgNames = {DDHeader=true, ResizeHandle=true, SliderValuePill=true, DropdownValue=true, DropdownList=true, SliderTrack=true, LogScroll=true}
		for _, obj in ipairs(SG:GetDescendants()) do
			pcall(function()
				if obj:IsA("UIStroke") then
					if obj.Parent and obj.Parent.Name ~= "AccentPreview" then obj.Color = Library.Theme.Border end
				elseif obj:IsA("TextLabel") or obj:IsA("TextBox") then
					if obj.TextColor3 == Color3.fromRGB(220,220,220) or obj.TextColor3 == Color3.fromRGB(230,230,238) then obj.TextColor3 = Library.Theme.TextPrimary end
				elseif obj:IsA("Frame") or obj:IsA("TextButton") then
					if surfaceNames[obj.Name] then obj.BackgroundColor3 = Library.Theme.Surface end
					if bgNames[obj.Name] then obj.BackgroundColor3 = Library.Theme.Background end
					if obj.Name == "TogglePill" and obj:GetAttribute("VenturaOn") ~= true then obj.BackgroundColor3 = Library.Theme.Background end
				end
			end)
		end
		GUI:_RefreshThemeVisuals()
		tw(Main,    { BackgroundColor3 = Library.Theme.Background }, TI_SLOW)
		tw(Nav,     { BackgroundColor3 = Library.Theme.Nav }, TI_SLOW)
		tw(Topbar,  { BackgroundColor3 = Library.Theme.Topbar }, TI_SLOW)
		tw(UserBox, { BackgroundColor3 = t.UserBox or Library.Theme.Surface }, TI_SLOW)
		tw(userSep, { BackgroundColor3 = Library.Theme.Border }, TI_SLOW)
		tw(searchBar, { BackgroundColor3 = Library.Theme.Surface }, TI_SLOW)
		tw(_mainStroke, { Color = Library.Theme.Border }, TI_SLOW)
		_styleMiniHUD()
		_styleMinimizeBubble()
		for _, p in ipairs(navPatches) do tw(p, { BackgroundColor3 = Library.Theme.Nav }, TI_SLOW) end
		return true
	end

