	function GUI:ImportConfig(raw, saveAfter)
		if type(raw) ~= "string" or raw == "" then return false end
		local ok, data = pcall(function() return GUI:_decodeConfig(raw) end)
		if not ok or type(data) ~= "table" or not next(data) then return false end
