		end
	end

	local function _runTrackedInstanceCleanups()
		for i = #GUI._trackedInstances, 1, -1 do
			local item = GUI._trackedInstances[i]
			local inst = item and item.instance
			if inst then
				local mode = tostring(item.mode or "destroy"):lower()
				pcall(function()
					if mode == "disable" then
						if inst.Enabled ~= nil then inst.Enabled = false end
					elseif mode == "hide" then
						if inst.Visible ~= nil then inst.Visible = false end
					else
						if inst.Destroy then inst:Destroy() end
					end
				end)
			end
		end
	end

	local function _runRegisteredCleanups()
		for i = #GUI._cleanupCallbacks, 1, -1 do
			local item = GUI._cleanupCallbacks[i]
