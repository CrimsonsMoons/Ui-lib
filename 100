		local rSlider, gSlider, bSlider, hexInput
		local _syncing = false
		local function syncSlidersFromColor(c)
			if _syncing then return end; _syncing = true
			if rSlider then rSlider:Set(math.floor(c.R*255+0.5), true) end
			if gSlider then gSlider:Set(math.floor(c.G*255+0.5), true) end
			if bSlider then bSlider:Set(math.floor(c.B*255+0.5), true) end
			if hexInput then hexInput:Set("#" .. GUI:_c3ToHex(c), true) end
			_syncing = false
		end

		local accentCP = S:ColorPicker({
			name     = "Custom Accent",
			tooltip  = "HSV color picker with live preview",
			default  = Library.Theme.Accent,
			callback = function(c) applyAccent(c); syncSlidersFromColor(c) end,
		})
		GUI._cfgSyncCallbacks.accent = function(c)
			syncSlidersFromColor(c)
			pcall(function() accentCP:Set(c, true) end)
			if GUI._cfgSyncCallbacks.accentPreset then
				pcall(GUI._cfgSyncCallbacks.accentPreset, GUI:_findAccentPresetFromColor(c))
			end
		end

		local function onSliderChange()
			if _syncing then return end
			local c = Color3.fromRGB(
				rSlider and rSlider.Value or 100,
				gSlider and gSlider.Value or 150,
				bSlider and bSlider.Value or 255)
			_syncing = true; accentCP:Set(c, true); if hexInput then hexInput:Set("#" .. GUI:_c3ToHex(c), true) end; _syncing = false
			applyAccent(c)
		end

		rSlider = S:Slider({ name="Red",   min=0, max=255, default=math.floor(Library.Theme.Accent.R*255+0.5), tooltip="Red channel",   callback=onSliderChange, color=Color3.fromRGB(255,85,95), showRange=false, valueFormatter=function(v) return "R: " .. tostring(v) end })
		gSlider = S:Slider({ name="Green", min=0, max=255, default=math.floor(Library.Theme.Accent.G*255+0.5), tooltip="Green channel", callback=onSliderChange, color=Color3.fromRGB(80,220,130), showRange=false, valueFormatter=function(v) return "G: " .. tostring(v) end })
		bSlider = S:Slider({ name="Blue",  min=0, max=255, default=math.floor(Library.Theme.Accent.B*255+0.5), tooltip="Blue channel",  callback=onSliderChange, color=Color3.fromRGB(80,150,255), showRange=false, valueFormatter=function(v) return "B: " .. tostring(v) end })

		local function parseRGB(s)
			local r,g,b = tostring(s):match("(%d+)[,%s]+(%d+)[,%s]+(%d+)")
			if r then return Color3.fromRGB(math.clamp(tonumber(r) or 0,0,255), math.clamp(tonumber(g) or 0,0,255), math.clamp(tonumber(b) or 0,0,255)) end
		end
		local function parseHex(s)
			local h = tostring(s or ""):gsub("#",""):gsub("0x","")
			if #h == 6 and h:match("^[%da-fA-F]+$") then return _hexToC3(h) end
		end
		hexInput = S:TextInput({
			name        = "HEX / RGB Value",
			placeholder = "#6496FF or 100,150,255",
			default     = "#" .. GUI:_c3ToHex(Library.Theme.Accent),
			tooltip     = "Type a hex or RGB color then press Enter",
			callback    = function(s)
				local c = parseHex(s) or parseRGB(s)
				if c then accentCP:Set(c); syncSlidersFromColor(c); applyAccent(c) end
			end,
		})

		S:Section({ name = "Keybinds" })
		S:Info({ text = "Click a badge, then press any key to rebind." })
		S:Keybind({ name="Toggle UI", tooltip="Show / hide the window", default=keys.toggle, callback=function(k) keys.toggle=k; GUI:MarkConfigDirty() end })

		S:Section({ name = "Window" })

		local scaleSlider = S:Slider({
			name     = "UI Scale",
			min      = 50, max = 200, default = currentScale, suffix = "%", showRange=true, valueFormatter=function(v) return tostring(v) .. "%" end,
			tooltip  = "Scale the window relative to its saved base size. Drag the bottom-right corner to freely resize.",
