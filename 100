	function GUI:ApplyConfig(data)
		if not data then return end
		if data.theme and Library.Themes[data.theme] then
			GUI:_applyTheme(data.theme)
			if GUI._cfgSyncCallbacks.theme then pcall(GUI._cfgSyncCallbacks.theme, data.theme) end
		end
		if data.accent then
			local c = GUI:_hexToC3(data.accent)
			applyAccentToRegistered(c)
			GUI:_syncAccentSettings(c, GUI:_findAccentPresetFromColor(c))
		else
			GUI:_syncAccentSettings(Library.Theme.Accent, GUI._activeAccentPreset)
		end
		-- Load base window size AND scale, then apply the scaled size to the real UI immediately.
		-- Old behavior loaded winW/winH first and skipped applying scale whenever winW/winH existed.
		WIN_MAX_W, WIN_MAX_H = getViewportLimit()
		if data.winW then
			winW = math.clamp(tonumber(data.winW) or winW, WIN_MIN_W, WIN_MAX_W)
		end
		if data.winH then
			winH = math.clamp(tonumber(data.winH) or winH, WIN_MIN_H, WIN_MAX_H)
		end
		if data.scale then
			currentScale = math.clamp(tonumber(data.scale) or 100, 50, 200)
		end
		local sw, sh = applyWindowScale(false, minimized and 34 or nil)
		MainWrap.Size = UDim2.new(0, sw, 0, minimized and 34 or sh)
		task.defer(function() if not _destroyed then applyWindowScale(false, minimized and 34 or nil); _applyResponsiveScale(true) end end)
		if GUI._cfgSyncCallbacks.scale then pcall(GUI._cfgSyncCallbacks.scale, currentScale) end
		-- 5.19+: responsive scaling is on by default but can be toggled off in Settings.
		_responsiveScaleEnabled = data.responsiveScale ~= false
		if GUI._cfgSyncCallbacks.responsiveScale then pcall(GUI._cfgSyncCallbacks.responsiveScale, _responsiveScaleEnabled) end
		_resizeSnapEnabled = data.resizeSnap ~= false
		_resizeSnapMode = tostring(data.resizeSnapMode or _resizeSnapMode or "center"):lower()
		if GUI._cfgSyncCallbacks.resizeSnap then pcall(GUI._cfgSyncCallbacks.resizeSnap, _resizeSnapEnabled) end
		if data.dragBounds ~= nil then
			options.dragBounds = data.dragBounds == true
		end
		-- 5.27: migrate old default Insert configs to RightControl.
		-- If the user later changes the Toggle UI keybind, that custom saved key still loads.
		if data.toggleKey and tostring(data.toggleKey) ~= "Insert" then
			local ok, k = pcall(function() return Enum.KeyCode[data.toggleKey] end)
			if ok and k and k ~= Enum.KeyCode.Unknown then keys.toggle = k end
		else
			keys.toggle = Enum.KeyCode.RightControl
		end
		keys.minimize = Enum.KeyCode.Unknown
		if data.miniVisible ~= nil then
			miniVisible = floatingMiniAllowed and data.miniVisible == true or false
			if miniFrame then miniFrame.Visible = miniVisible end
			if GUI._cfgSyncCallbacks.miniVisible then pcall(GUI._cfgSyncCallbacks.miniVisible, miniVisible) end
		end
		if floatingMiniAllowed and miniFrame and data.miniX and data.miniY then
			miniFrame.Position = UDim2.new(0, tonumber(data.miniX) or 14, 0, tonumber(data.miniY) or 14)
		end
		-- 5.19: FPS / ping stats are on by default but can be toggled off in Settings.
		wmStatsVisible = data.watermarkStatsVisible ~= false
		_syncWatermarkStats()
		if GUI._cfgSyncCallbacks.watermarkStats then pcall(GUI._cfgSyncCallbacks.watermarkStats, wmStatsVisible) end
		if wmFrame then
			local savedX = tonumber(data.watermarkX) or WM_DEFAULT_X
			local savedY = tonumber(data.watermarkY) or WM_DEFAULT_Y
			local savedScaleX = tonumber(data.watermarkScaleX)
			local savedScaleY = tonumber(data.watermarkScaleY) or 0
			-- Old configs did not save scale and usually forced the bar back to the left.
			-- Upgrade those to the new top-right default. New configs keep their dragged position.
			if savedScaleX == nil then
				wmFrame.AnchorPoint = Vector2.new(1, 0)
				wmFrame.Position = UDim2.new(1, WM_DEFAULT_X, 0, WM_DEFAULT_Y)
			else
				wmFrame.Position = UDim2.new(savedScaleX, savedX, savedScaleY, savedY)
			end
		end
		-- Old minimize bubble positions are intentionally ignored because the minimize UI was removed.
		GUI._loadedConfigData = data
		-- After old saved positions are restored, recover visibility once more so tiny/small
		-- Roblox window sizes never leave the UI lost off-screen.
		if _resizeSnapEnabled then
			task.defer(function() if not _destroyed then _applyResponsiveScale(true) end end)
		end
	end

	GUI._startupLoadedConfig = GUI:LoadConfig()
	GUI._loadedConfigData = GUI._startupLoadedConfig
	if GUI._startupLoadedConfig then
		GUI:ApplyConfig(GUI._startupLoadedConfig)
	elseif options.theme and Library.Themes[options.theme] then
		GUI:SetTheme(options.theme, true)
	end

